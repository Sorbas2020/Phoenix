2481   0A50             ;*****************************************************************************
2482   0A50             ;* Handle alien control states for all aliens.
2483   0A50             ;* This routine has a bug!
2484   0A50             ;* Loop goes 20 times for 16 aliens. But bit 3 or 4 is not set at
2485   0A50             ;* UpdateScreenObjects. So luckily no effect.
2486   0A50             ;* Possible fix would be: 'CP $F0' at $0A63.
2487   0A50             ;*****************************************************************************
2488   0A50             AlienDataController:
2489   0A50 01 70 4B                           LD      BC,M4B70            ; alien data structure (grid)
2490   0A53 11 B0 4B                           LD      DE,M4BB0            ; alien data structure (screen ram)
2491   0A56             L0A56:
2492   0A56 C5                                 PUSH    BC                  ;
2493   0A57 CD 18 07                           CALL    UpdateScreenObjects ;
2494   0A5A C1                                 POP     BC                  ;
2495   0A5B 79                                 LD      A,C                 ;
2496   0A5C C6 04                              ADD     $04                 ;
2497   0A5E 4F                                 LD      C,A                 ;
2498   0A5F C6 40                              ADD     $40                 ;
2499   0A61 5F                                 LD      E,A                 ;
2500   0A62 50                                 LD      D,B                 ;
2501   0A63 A7                                 AND     A                   ; updates the zero flag (bug)
2502   0A64 C2 56 0A                           JP      NZ,L0A56            ;
2503   0A67 C9                                 RET                         ;
2504   0A68             
2505   0A6C                                    .ORG $0A6C
2506   0A6C             ;*****************************************************************************
2507   0A6C             ;* Get screen ram adress for all aliens.
2508   0A6C             ;*****************************************************************************
2509   0A6C             L0A6C:
2510   0A6C 01 70 4B                           LD      BC,M4B70            ; data structure for alien control and screen coordinate
2511   0A6F 11 B3 4B                           LD      DE,M4BB3            ; data structure for alien screen ram address
2512   0A72             L0A72:
2513   0A72 C5                                 PUSH    BC                  ;
2514   0A73 D5                                 PUSH    DE                  ;
2515   0A74 0A                                 LD      A,(BC)              ;
2516   0A75 E6 18                              AND     $18                 ; mask out 0001_1000
2517   0A77 CA 8A 0A                           JP      Z,L0A8A             ; if 0 then skip the mapping
2518   0A7A EB                                 EX      DE,HL               ;
2519   0A7B 56                                 LD      D,(HL)              ;
2520   0A7C 2B                                 DEC     HL                  ;
2521   0A7D 5E                                 LD      E,(HL)              ;
2522   0A7E 2B                                 DEC     HL                  ;
2523   0A7F 72                                 LD      (HL),D              ;
2524   0A80 2B                                 DEC     HL                  ;
2525   0A81 73                                 LD      (HL),E              ;
2526   0A82 EB                                 EX      DE,HL               ;
2527   0A83 13                                 INC     DE                  ;
2528   0A84 13                                 INC     DE                  ;
2529   0A85 03                                 INC     BC                  ;
2530   0A86 03                                 INC     BC                  ;
2531   0A87 CD BA 09                           CALL    GetScreenRamAddress ;
2532   0A8A             L0A8A:
2533   0A8A D1                                 POP     DE                  ;
2534   0A8B C1                                 POP     BC                  ;
2535   0A8C 79                                 LD      A,C                 ;
2536   0A8D C6 04                              ADD     $04                 ;
2537   0A8F 4F                                 LD      C,A                 ;
2538   0A90 7B                                 LD      A,E                 ;
2539   0A91 C6 04                              ADD     $04                 ;
2540   0A93 5F                                 LD      E,A                 ;
2541   0A94 FE 03                              CP      $03                 ;
2542   0A96 C2 72 0A                           JP      NZ,L0A72            ;
2543   0A99 C9                                 RET                         ;
2544   0A9A             
2545   0AA0                                    .ORG $0AA0
2546   0AA0             ;*****************************************************************************
2547   0AA0             ;* Handler for the player shield.
2548   0AA0             ;*****************************************************************************
2549   0AA0             DrawShields:
2550   0AA0 2E E2                              LD      L,PlayerShipMSB & $FF     ; HL=43E2 Player's screen memory location
2551   0AA2 56                                 LD      D,(HL)              ; Get the PlayerScreenRamMSB
2552   0AA3 23                                 INC     HL                  ; Get the ... PlayerScreenRamLSB
2553   0AA4 5E                                 LD      E,(HL)              ; ... LSB (ignore any fine bit shifting of the player)
2554   0AA5 CD 10 02                           CALL    LeftOneColumn       ; Shield pictures begin one column to the left of the ship
2555   0AA8 1B                                 DEC     DE                  ; Shield pictures begin one row above the ship
2556   0AA9 01 04 04                           LD      BC,$0404            ; Shiled images are 4x4
2557   0AAC 2E A6                              LD      L,ShieldCount & $FF ; Decrement the ...
2558   0AAE 35                                 DEC     (HL)                ; ... shield counter
2559   0AAF 7E                                 LD      A,(HL)              ; Current shield counter value
2560   0AB0 21 F0 17                           LD      HL,FourByFourEmpty  ; Blank 4x4
2561   0AB3 FE C0                              CP      $C0                 ; Shield time done?
2562   0AB5 CA 48 0B                           JP      Z,ShieldsExpired    ; Yes ... turn shields off
2563   0AB8 21 70 17                           LD      HL,T1770            ; Four shield-active pictures
2564   0ABB E6 0C                              AND     $0C                 ; Drop lower 2 bits (0000_1100). Images change every 4 ticks.
2565   0ABD 07                                 RLCA                        ; Multiply by 4 ...
2566   0ABE 07                                 RLCA                        ; ... to get a 16-byte offest (4x4 pictures)
2567   0ABF 85                                 ADD     A,L                 ; Point to the ...
2568   0AC0 6F                                 LD      L,A                 ; ... correct image
2569   0AC1 C3 D6 0A                           JP      DrawImageCbyB       ; Draw the new shield image
2570   0AC4             
2571   0AD6                                    .ORG $0AD6
2572   0AD6             ;*****************************************************************************
2573   0AD6             ; B is number of rows
2574   0AD6             ; C is number of columns
2575   0AD6             ; HL is the data
2576   0AD6             ; DE is the pointer to the screen
2577   0AD6             ;*****************************************************************************
2578   0AD6             DrawImageCbyB:
2579   0AD6 D5                                 PUSH    DE                  ; Hold screen pointer
2580   0AD7 C5                                 PUSH    BC                  ; Hold width/Height
2581   0AD8             L0AD8:
2582   0AD8 7E                                 LD      A,(HL)              ; Character to ...
2583   0AD9 12                                 LD      (DE),A              ; ... the screen
2584   0ADA 23                                 INC     HL                  ; Next in data
2585   0ADB 13                                 INC     DE                  ; Next column on screen
2586   0ADC 05                                 DEC     B                   ; All rows done in this column?
2587   0ADD C2 D8 0A                           JP      NZ,L0AD8            ; No ... finish the rows
2588   0AE0 C1                                 POP     BC                  ; Restore the counters
2589   0AE1 D1                                 POP     DE                  ; Restore the screen pointer
2590   0AE2 CD 17 02                           CALL    RightOneColumn      ; Move over one column
2591   0AE5 0D                                 DEC     C                   ; All columns done?
2592   0AE6 C2 D6 0A                           JP      NZ,DrawImageCbyB    ; No ... do all columns
2593   0AE9 C9                                 RET                         ; Done
2594   0AEA             
2595   0AEA             ;*****************************************************************************
2596   0AEA             ;* Game state 4.
2597   0AEA             ;* Player ship partikel explosion.
2598   0AEA             ;*****************************************************************************
2599   0AEA             L0AEA:
2600   0AEA 21 B9 43                           LD      HL,CounterB9        ;
2601   0AED 7E                                 LD      A,(HL)              
2602   0AEE E6 F8                              AND     $F8                 
2603   0AF0 77                                 LD      (HL),A              
2604   0AF1 32 00 58                           LD      (scrollRegister),A  ; 58xx scroll register
2605   0AF4 2E E2                              LD      L,$E2               
2606   0AF6 56                                 LD      D,(HL)              
2607   0AF7 2C                                 INC     L                   
2608   0AF8 5E                                 LD      E,(HL)              
2609   0AF9 CD 10 02                           CALL    LeftOneColumn       ;
2610   0AFC 1B                                 DEC     DE                  
2611   0AFD 00                                 NOP                         
2612   0AFE 2E A5                              LD      L,$A5               
2613   0B00 35                                 DEC     (HL)                
2614   0B01 7E                                 LD      A,(HL)              
2615   0B02 CA 15 0B                           JP      Z,L0B15             ;
2616   0B05 FE 20                              CP      $20                 
2617   0B07 DA A0 0B                           JP      C,L0BA0             ;
2618   0B0A CA 80 03                           JP      Z,ClearForeground   ;
2619   0B0D C3 BA 0B                           JP      L0BBA               ;
2620   0B10             
2621   0B15                                    .ORG $0B15
2622   0B15             L0B15:
2623   0B15 2D                                 DEC     L                   ;
2624   0B16 36 05                              LD      (HL),$05            
2625   0B18 2D                                 DEC     L                   
2626   0B19 7E                                 LD      A,(HL)              
2627   0B1A C6 90                              ADD     $90                 
2628   0B1C 6F                                 LD      L,A                 
2629   0B1D 7E                                 LD      A,(HL)              
2630   0B1E A7                                 AND     A                   ; updates the zero flag
2631   0B1F C8                                 RET     Z                   
2632   0B20 35                                 DEC     (HL)                
2633   0B21 E5                                 PUSH    HL                  
2634   0B22 CD 67 03                           CALL    UpdateLivesScreen   ;
2635   0B25 E1                                 POP     HL                  
2636   0B26 7E                                 LD      A,(HL)              
2637   0B27 A7                                 AND     A                   ; updates the zero flag
2638   0B28 C8                                 RET     Z                   
2639   0B29 2E A4                              LD      L,$A4               
2640   0B2B 36 00                              LD      (HL),$00            
2641   0B2D C9                                 RET                         
2642   0B2E             
2643   0B38                                    .ORG $0B38
2644   0B38             ; Player ship X position mapping table
2645   0B38             T0B38:
2646   0B38 00 08                              .DB $00, $08
2647   0B3A 01 09                              .DB $01, $09
2648   0B3C 02 0A                              .DB $02, $0A
2649   0B3E 03 0B                              .DB $03, $0B
2650   0B40 03 0B                              .DB $03, $0B
2651   0B42 02 0A                              .DB $02, $0A
2652   0B44 01 09                              .DB $01, $09
2653   0B46 00 08                              .DB $00, $08
2654   0B48             
2655   0B48             ;*****************************************************************************
2656   0B48             ;* The player shield is expired.
2657   0B48             ;* Shield and player gets removed from screen.
2658   0B48             ;* PlayerShipX position is reset.
2659   0B48             ;*****************************************************************************
2660   0B48             ShieldsExpired:
2661   0B48 CD D6 0A                           CALL    DrawImageCbyB       ;
2662   0B4B 21 C0 43                           LD      HL,PlayerState      ;
2663   0B4E 36 0C                              LD      (HL),$0C            
2664   0B50 2C                                 INC     L                   
2665   0B51 36 0C                              LD      (HL),$0C            
2666   0B53 2C                                 INC     L                   
2667   0B54 7E                                 LD      A,(HL)              
2668   0B55 E6 F8                              AND     $F8                 
2669   0B57 F6 03                              OR      $03                 
2670   0B59 77                                 LD      (HL),A              
2671   0B5A C9                                 RET                         
2672   0B5B             
2673   0B60                                    .ORG $0B60
2674   0B60             ;*****************************************************************************
2675   0B60             ;* Game state 5.
2676   0B60             ;* 'GAME OVER'.
2677   0B60             ;*****************************************************************************
2678   0B60             L0B60:
2679   0B60 21 A5 43                           LD      HL,CounterA5        ;
2680   0B63 34                                 INC     (HL)                
2681   0B64 7E                                 LD      A,(HL)              
2682   0B65 FE 40                              CP      $40                 
2683   0B67 CA A0 03                           JP      Z,ClearBackground   ;
2684   0B6A 21 00 1A                           LD      HL,T1A00            ; "        GAME  OVER        "
2685   0B6D 0E 01                              LD      C,$01               
2686   0B6F FE 80                              CP      $80                 
2687   0B71 C2 95 0B                           JP      NZ,L0B95            ; 
2688   0B74 21 A4 43                           LD      HL,GameState        ; Next interval game state ...
2689   0B77 36 00                              LD      (HL),$00            ; ... is 0 (new game start)
2690   0B79 2E 90                              LD      L,$90               
2691   0B7B 7E                                 LD      A,(HL)              
2692   0B7C 2C                                 INC     L                   
2693   0B7D B6                                 OR      (HL)                
2694   0B7E C0                                 RET     NZ                  
2695   0B7F AF                                 XOR     A                   ; A=0
2696   0B80 2E 98                              LD      L,$98               
2697   0B82 77                                 LD      (HL),A              
2698   0B83 2C                                 INC     L                   
2699   0B84 77                                 LD      (HL),A              
2700   0B85 2E A2                              LD      L,$A2               
2701   0B87 77                                 LD      (HL),A              
2702   0B88 2C                                 INC     L                   
2703   0B89 7E                                 LD      A,(HL)              
