6059   3000             ;*****************************************************************************
6060   3000             ;* AlienBehaviorUpdate.
6061   3000             ;* This is the 'core of the matter'!
6062   3000             ;* It handles all attack patterns of the aliens
6063   3000             ;* and the randomization of selection.
6064   3000             ;* The selected patterns do always fit on the screen,
6065   3000             ;* even if the alien formation is further down. (phase 1, 2, 3)
6066   3000             ;*****************************************************************************
6067   3000             L3000:
6068   3000 21 93 43                           LD      HL,Counter93        ; 
6069   3003 7E                                 LD      A,(HL)              ; load and save ram value
6070   3004 34                                 INC     (HL)                ; increment Counter93
6071   3005 E6 07                              AND     $07                 ; masc out 0000_0111 the saved value in order to count from 0 to 7
6072   3007 21 18 30                           LD      HL,T3018            ; base of jump table
6073   300A 07                                 RLCA                        ; Multiply by 2 to get a 2 byte offset
6074   300B 85                                 ADD     A,L                 ;
6075   300C 6F                                 LD      L,A                 ;
6076   300D 7E                                 LD      A,(HL)              ; get MSB from jump table
6077   300E 23                                 INC     HL                  ;
6078   300F 6E                                 LD      L,(HL)              ; get LSB from jump table
6079   3010 67                                 LD      H,A                 ;
6080   3011 E9                                 JP      (HL)                ; jump to the corresponding function
6081   3012             ; from jump table T3018 if Counter93 is 7
6082   3012             L3012:
6083   3012 C9                                 RET                         ;
