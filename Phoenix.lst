0456   0000             
0457   0000             ; Bird extended storage
0458   0000             ; Used for all levels with the 8 birds.
0459   0000             B4BC0                  .EQU $4BC0       ;
0460   0000             B4BC1                  .EQU $4BC1       ;
0461   0000             B4BC2                  .EQU $4BC2       ;
0462   0000             B4BC3                  .EQU $4BC3       ;
0463   0000             B4BC4                  .EQU $4BC4       ;
0464   0000             B4BC5                  .EQU $4BC5       ;
0465   0000             
0466   0000             B4BD1                  .EQU $4BD1       ;
0467   0000             B4BD2                  .EQU $4BD2       ;
0468   0000             B4BD3                  .EQU $4BD3       ;
0469   0000             B4BD4                  .EQU $4BD4       ;
0470   0000             B4BD5                  .EQU $4BD5       ;
0471   0000             B4BD6                  .EQU $4BD6       ;
0472   0000             B4BD7                  .EQU $4BD7       ;
0473   0000             
0474   0000             B4BED                  .EQU $4BED       ;
0475   0000             B4BEE                  .EQU $4BEE       ;
0476   0000             B4BEF                  .EQU $4BEF       ;
0477   0000             
0478   0000             ; Stack
0479   0000             Stack                  .EQU $4BF0       ;Stack space 4BF0:4BFF
0480   0000             
0481   0000             ;HW
0482   0000             videoRegister          .EQU $5000       ;Lower bit selects the RAM bank
0483   0000             scrollRegister         .EQU $5800       ;Screen scrolling
0484   0000             SOUNDCTLA              .EQU $6000       ;Sound control A
0485   0000             SOUNDCTLB              .EQU $6800       ;Sound control B
0486   0000             IN0                    .EQU $7000       ;Player inputs
0487   0000             DSW0                   .EQU $7800       ;DIP switch settings
0488   0000             
0489   0000                                    .ORG $0000
0490   0000             L0000:
0491   0000 00                                 NOP                         ; Start/restart and interrupts end up at 0008
0492   0001 00                                 NOP                         ;
0493   0002 00                                 NOP                         ;
0494   0003 00                                 NOP                         ;
0495   0004 00                                 NOP                         ;
0496   0005 00                                 NOP                         ;
0497   0006 00                                 NOP                         ;
0498   0007 00                                 NOP                         ;
0499   0008             ; 
0500   0008 31 FF 4B                           LD      SP,$4BFF            ; Top-ish of RAM
0501   000B 26 50                              LD      H,videoRegister >> 8
0502   000D 36 00                              LD      (HL),$00            ; Select the first bank of RAM
0503   000F CD 50 00                           CALL    InitSoundScreen     ; Turn sound off and clear both screen areas
0504   0012 21 00 18                           LD      HL,T1800            ; Screen draw info
0505   0015 0E 03                              LD      C,$03               ; 3 columns (rotated to 3 rows)
0506   0017 CD D0 01                           CALL    PrintTextLines      ; Draw the first 3 rows of the background (scores and coins)
0507   001A             
0508   001A             ;*****************************************************************************
0509   001A             ;* Main loop begin
0510   001A             ;*****************************************************************************
0511   001A             MainLoop:
0512   001A CD 80 00                           CALL    WaitVBlankCoin      ; Wait for VBlank and count any coins
0513   001D 3A A2 43                           LD      A,(GameOrAttract)   ;
0514   0020 A7                                 AND     A                   ; updates the zero flag
0515   0021 CA 2D 00                           JP      Z,L002D             ; if 'Attract mode'
0516   0024             ; Game mode
0517   0024 CD 00 04                           CALL    GameStateMachine    ; controls the flow of the game.
0518   0027 CD 00 27                           CALL    UpdateScoresAndSound
0519   002A C3 1A 00                           JP      MainLoop            ; Back to top of main loop
0520   002D             ; Attract mode (no sound, no scoreing, no manual steering)
0521   002D             L002D:
0522   002D 3E 0F                              LD      A,$0F               ; 0000_1111 mute the sound chip TMS36XX
0523   002F 26 60                              LD      H,SOUNDCTLA >> 8    ; 60xx sound A
0524   0031 77                                 LD      (HL),A              ;
0525   0032 26 68                              LD      H,SOUNDCTLB >> 8    ; 68xx sound B
0526   0034 77                                 LD      (HL),A              ;
0527   0035 CD 77 03                           CALL    UpdateSoundControlRAM
0528   0038 00                                 NOP                         ;
0529   0039 CD E0 17                           CALL    CoinChecking        ;
0530   003C A7                                 AND     A                   ; updates the zero flag
0531   003D CA 46 00                           JP      Z,L0046             ; No credits ... continue splash
0532   0040 CD 88 02                           CALL    PromptForStartGame  ;
0533   0043 C3 1A 00                           JP      MainLoop            ; Back to top of main loop
0534   0046             ; 
0535   0046             L0046:
0536   0046 CD E3 00                           CALL    SplashAndDemo       ;
0537   0049 C3 1A 00                           JP      MainLoop            ; Back to top of main loop
0538   004C             ; Main loop end.
0539   004C             
0540   0050                                    .ORG $0050
0541   0050             ;*****************************************************************************
0542   0050             ;* Initialize the sound (off) and screen (clear)
0543   0050             ;*****************************************************************************
0544   0050             InitSoundScreen:
0545   0050 26 68                              LD      H,SOUNDCTLB >> 8    ; 68xx sound B
0546   0052 36 00                              LD      (HL),$00            ; Sound off
0547   0054 26 60                              LD      H,SOUNDCTLA >> 8    ; 60xx sound A
0548   0056 36 00                              LD      (HL),$00            ; Sound off
0549   0058 26 58                              LD      H,scrollRegister >> 8
0550   005A 36 00                              LD      (HL),$00            ; First memory bank
0551   005C CD 6B 00                           CALL    ClearRAMBank        ; Clear the bank (includes screen)
0552   005F 26 50                              LD      H,videoRegister >> 8
0553   0061 36 01                              LD      (HL),$01            ; Second memory bank
0554   0063 CD 6B 00                           CALL    ClearRAMBank        ; Clear the bank (includes screen)
0555   0066 26 50                              LD      H,videoRegister >> 8
0556   0068 36 00                              LD      (HL),$00            ; Back to first memory bank
0557   006A C9                                 RET                         ; Done
0558   006B             
0559   006B             ;*****************************************************************************
0560   006B             ;* Clear a RAM Bank (bank 0 or 1)
0561   006B             ;* Set the lower bit of the video register to pick the bank before calling.
0562   006B             ;* 4000 - 4BF8
0563   006B             ;* We call this function, which means we don't want to clear the return on the stack.
0564   006B             ;* That's why we start clearing at 4BF8 instead of 4BFF.
0565   006B             ;* Since screen memory is part of this bank, we are clearing the screen too.
0566   006B             ;*****************************************************************************
0567   006B             ClearRAMBank:
0568   006B 21 F8 4B                           LD      HL,$4BF8            ; Highest point ... skip the top of the stack
0569   006E 3E 3F                              LD      A,$3F               ; Stop when H reaches 3F
0570   0070             L0070:
0571   0070 36 00                              LD      (HL),$00            ; Clear the memory
0572   0072 2B                                 DEC     HL                  ; Point to next
0573   0073 BC                                 CP      H                   ; All done?
0574   0074 C2 70 00                           JP      NZ,L0070            ; No ... go back for all
0575   0077 C9                                 RET                         ; Done
0576   0078             
0577   0078             ;*****************************************************************************
0578   0078             ;* Slow printing the static texts and filling the scroll register
0579   0078             ;* with background tiles.
0580   0078             ;* Only used at attract mode during the intro splash.
0581   0078             ;*****************************************************************************
0582   0078             SlowPrintScrollRegisterUpdate:
0583   0078 CD 96 01                           CALL    SlowPrintScoreAverageTable
0584   007B C3 F0 06                           JP      L06F0               ; update scroll register and fill background
0585   007E             
0586   0080                                    .ORG $0080
0587   0080             ;*****************************************************************************
0588   0080             ;* Wait for the vertical blanking and then handle coin counting
0589   0080             ;*****************************************************************************
0590   0080             WaitVBlankCoin:
0591   0080 26 78                              LD      H,DSW0 >> 8         ; 78xx DSW0 Check ...
0592   0082 7E                                 LD      A,(HL)              ; ... screen blanking flag
0593   0083 E6 80                              AND     $80                 ; Wait for it ...
0594   0085 CA 80 00                           JP      Z,WaitVBlankCoin    ; ... to set
0595   0088             ; 
0596   0088             L0088:
0597   0088 7E                                 LD      A,(HL)              ; Check screen blanking flag
0598   0089 E6 80                              AND     $80                 ; Wait for it ...
0599   008B C2 88 00                           JP      NZ,L0088            ; ... to clear (0=in blanking)
0600   008E 26 70                              LD      H,IN0 >> 8          ; 70xx IN0 Current value ...
0601   0090 7E                                 LD      A,(HL)              ; ... of IN0 inputs
0602   0091 21 A0 43                           LD      HL,IN0Current       ; Value from ...
0603   0094 46                                 LD      B,(HL)              ; ... last read
0604   0095 77                                 LD      (HL),A              ; Store new value
0605   0096 2C                                 INC     L                   ; To 43A1
0606   0097 70                                 LD      (HL),B              ; Store old value
0607   0098 2E 9B                              LD      L,$9B               ; Bump the ...
0608   009A CD 00 02                           CALL    AddOneToMem         ; ... ?? counter
0609   009D 2E 8F                              LD      L,$8F               ; Get number ...
0610   009F 7E                                 LD      A,(HL)              ; ... of coins
0611   00A0             ;
0612   00A0             ; !! There are two digits for "coins" on the screen, but only the one's digit is
0613   00A0             ; !! changed. Once you get to 9, the code stops counting. It takes the coin
0614   00A0             ; !! from you, but it doesn't give you credit.
0615   00A0             ;
0616   00A0 FE 09                              CP      $09                 ; Already 9?
0617   00A2 C8                                 RET     Z                   ; Yes ... nothing more to check
0618   00A3 D2 00 00                           JP      NC,L0000            ; More than 9? OOPS -- soft reset
0619   00A6 06 01                              LD      B,$01               ; Coin bit of the input register
0620   00A8 CD BB 00                           CALL    CheckInputBits      ; Has the coin input gone from 1 to 0?
0621   00AB C8                                 RET     Z                   ; No ... no coins inserted ... done
0622   00AC 2E 8F                              LD      L,$8F               ; Add one ...
0623   00AE 34                                 INC     (HL)                ; ... to coin count
0624   00AF 7E                                 LD      A,(HL)              ; Current value ...
0625   00B0 C6 20                              ADD     $20                 ; ... to number tile
0626   00B2 32 42 41                           LD      ($4142),A           ; Change number of coins on screen
0627   00B5 C9                                 RET                         ; Done
0628   00B6             
0629   00BB                                    .ORG $00BB
0630   00BB             ;*****************************************************************************
0631   00BB             ;* Check to see if a particular bit(s) in the input register has changed
0632   00BB             ;* from 1 to 0 since last we checked. Return NZ if transitioned from 1 to 0.
0633   00BB             ;*****************************************************************************
0634   00BB             CheckInputBits:
0635   00BB 21 A0 43                           LD      HL,IN0Current       ; Get current ...
0636   00BE 7E                                 LD      A,(HL)              ; ... input value
0637   00BF 2F                                 CPL                         ; Flip the current bits
0638   00C0 A0                                 AND     B                   ; Mask off all but the ones we are checking
0639   00C1 2C                                 INC     L                   ; Point to last input value
0640   00C2 A6                                 AND     (HL)                ; Zero unles new bit is 0 and old is 1
0641   00C3 C9                                 RET                         ; Return state
0642   00C4             
0643   00C4             ;*****************************************************************************
0644   00C4             ;* Prints the number pointed to by HL (points to the end of the number) to the screen pointed
0645   00C4             ;* to by DE (points to the end of the screen area). B is the number of digits to print.
0646   00C4             ;*****************************************************************************
0647   00C4             PrintNumber:
0648   00C4 7E                                 LD      A,(HL)              ; Get the two digits
0649   00C5 E6 0F                              AND     $0F                 ; Keep the LSB
0650   00C7 F6 20                              OR      $20                 ; Offset to number tile
0651   00C9 12                                 LD      (DE),A              ; Store the number tile to screen memory
0652   00CA CD 10 02                           CALL    LeftOneColumn       ; next screen position
0653   00CD 05                                 DEC     B                   ; All done?
0654   00CE C8                                 RET     Z                   ; Yes ... out
0655   00CF 7E                                 LD      A,(HL)              ; Keep the ...
0656   00D0 0F                                 RRCA                        ; ...
0657   00D1 0F                                 RRCA                        ; ...
0658   00D2 0F                                 RRCA                        ; ...
0659   00D3 0F                                 RRCA                        ; ...
0660   00D4 E6 0F                              AND     $0F                 ; ... LSB
0661   00D6 F6 20                              OR      $20                 ; Offset to number tile
0662   00D8 12                                 LD      (DE),A              ; Store the number tile to screen memory
0663   00D9 CD 10 02                           CALL    LeftOneColumn       ; next screen position
0664   00DC 2B                                 DEC     HL                  ; Next data position
0665   00DD 05                                 DEC     B                   ; All digits done?
0666   00DE C2 C4 00                           JP      NZ,PrintNumber      ; No ... keep going
0667   00E1 C9                                 RET                         ; Yes ... out
0668   00E2             
0669   00E3                                    .ORG $00E3
0670   00E3             ;*****************************************************************************
0671   00E3             ;* Handles the intro splash and the game demo.
0672   00E3             ;*****************************************************************************
0673   00E3             SplashAndDemo:
0674   00E3 21 99 43                           LD      HL,M4399            ; starts with 0
0675   00E6 CD 00 02                           CALL    AddOneToMem         ; increases it by one
0676   00E9 01 01 00                           LD      BC,$0001            ;
0677   00EC CD 58 02                           CALL    CompareBCtoMem      ;
0678   00EF CA E1 01                           JP      Z,PrintCopyright    ; do if $4398:$4399 is >= 00 01
0679   00F2 01 02 00                           LD      BC,$0002            ;
0680   00F5 11 1F 01                           LD      DE,$011F            ; used as delay counter
0681   00F8 CD 60 02                           CALL    SubtractIfEnough    ;
0682   00FB D2 96 01                           JP      NC,SlowPrintScoreAverageTable
0683   00FE 01 20 01                           LD      BC,$0120            ; for a longer break
0684   0101 CD 58 02                           CALL    CompareBCtoMem      ;
0685   0104 CA CA 0B                           JP      Z,DrawScoreAverageTableTiles
0686   0107 0E B0                              LD      C,$B0               ; for a short break
0687   0109 CD 58 02                           CALL    CompareBCtoMem      ;
0688   010C CA E1 01                           JP      Z,PrintCopyright    ; do if $4398:$4399 is >= 01 B0
0689   010F 0E B8                              LD      C,$B8               ;
0690   0111 CD 58 02                           CALL    CompareBCtoMem      ;
0691   0114 CA 80 05                           JP      Z,InitGlobalLevelData
0692   0117 0E C0                              LD      C,$C0               ; for a short break
0693   0119 11 DF 02                           LD      DE,$02DF            ;
0694   011C CD 60 02                           CALL    SubtractIfEnough    ;
0695   011F D2 78 00                           JP      NC,SlowPrintScrollRegisterUpdate
0696   0122 01 00 03                           LD      BC,$0300            ;
0697   0125 11 AF 03                           LD      DE,$03AF            ;
0698   0128 CD 60 02                           CALL    SubtractIfEnough    ;
0699   012B D2 DC 21                           JP      NC,DrawIntroBirdAnimationFrame
0700   012E 01 E6 03                           LD      BC,$03E6            ;
0701   0131 11 FF FF                           LD      DE,$FFFF            ;
0702   0134 CD 60 02                           CALL    SubtractIfEnough    ;
0703   0137 D2 B0 03                           JP      NC,GameDemo         ; do if $4398:$4399 is >= 03 E6
0704   013A C9                                 RET                         ;
0705   013B             
0706   0140                                    .ORG $0140
0707   0140             ;*****************************************************************************
0708   0140             ;* Clears foreground and background but leaves the 3 score rows.
0709   0140             ;*****************************************************************************
0710   0140             ClearForeAndBackground:
0711   0140 CD A0 03                           CALL    ClearBackground     ; Clear the background
0712   0143 CD 80 00                           CALL    WaitVBlankCoin      ; Wait for VBlank
0713   0146 CD 80 03                           CALL    ClearForeground     ; Clear the foreground (leave the 3 score rows)
0714   0149 21 A3 43                           LD      HL,GameAndDemoOrSplash
0715   014C 36 02                              LD      (HL),$02            ; set to: 'Intro splash'
0716   014E 2C                                 INC     L                   ; GameState
0717   014F 36 00                              LD      (HL),$00            ; to 0
0718   0151 00                                 NOP                         ; Old command removed or space for a future replace patch
0719   0152 00                                 NOP                         ; ..
0720   0153 00                                 NOP                         ; ..
0721   0154 2E B8                              LD      L,$B8               ; LevelAndRound, $43B9, AliensLeft, BirdsLeft, $43BC, $43BD, BonusLivesAt, $43BF to 0
0722   0156 06 08                              LD      B,$08               ; number of bytes to clear
0723   0158 CD D8 05                           CALL    ClearBbytesAtHL     ;
0724   015B 2E BA                              LD      L,$BA               ; Set AliensLeft
0725   015D 36 10                              LD      (HL),$10            ; to 16 aliens left in wave
0726   015F 2E BE                              LD      L,$BE               ;
0727   0161 3A 00 78                           LD      A,(DSW0)            ; 78xx DSW0, get DIP switch settings
0728   0164 E6 0C                              AND     $0C                 ; mask out 0000_1100 the Bonus lives
0729   0166 07                                 RLCA                        ; rotate left ..
0730   0167 07                                 RLCA                        ; .. to 0011_0000
0731   0168 C6 30                              ADD     $30                 ; $30, $40, $50, or $60
0732   016A 77                                 LD      (HL),A              ; save to BonusLivesAt
0733   016B 26 58                              LD      H,scrollRegister >> 8
0734   016D 36 00                              LD      (HL),$00            ; init screen scrolling
0735   016F CD 80 00                           CALL    WaitVBlankCoin      ;
0736   0172 C9                                 RET                         ;
0737   0173             
0738   0173             ;*****************************************************************************
0739   0173             ;* Used for the game demo during attract mode.
0740   0173             ;* Returning the bits for feeding the IN0Current for the simulated player inputs.
0741   0173             ;* Resulting values are depending on $4398:$4399 .
0742   0173             ;* Counter value goes from $03E6 to $1510 during the demo.
0743   0173             ;* 1010_1110...move left
0744   0173             ;* 1100_1110...move right
0745   0173             ;* 1111_1110...push fire
0746   0173             ;* 0111_1110...push shield
0747   0173             ;*****************************************************************************
0748   0173             GetPlayerInputsForDemo:
0749   0173 7E                                 LD      A,(HL)              ; get $4399 (LSB from 16 bit counter)
0750   0174 E6 7F                              AND     $7F                 ; mask out 0111_1111, (counter goes from 00 to $7F)
0751   0176 06 CE                              LD      B,$CE               ; return : 1100_1110...move right
0752   0178 FE 1F                              CP      $1F                 ; 1st trigger point of demo
0753   017A D8                                 RET     C                   ; return if greater
0754   017B 06 FE                              LD      B,$FE               ; 1111_1110...push fire
0755   017D C8                                 RET     Z                   ; return if equal
0756   017E 06 AE                              LD      B,$AE               ; 1010_1110...move left
0757   0180 FE 5F                              CP      $5F                 ; 2nd trigger point of demo
0758   0182 D8                                 RET     C                   ; return if greater
0759   0183 06 FE                              LD      B,$FE               ; 1111_1110...push fire
0760   0185 C8                                 RET     Z                   ; return if equal
0761   0186 06 CE                              LD      B,$CE               ; 1100_1110...move right
0762   0188 FE 7F                              CP      $7F                 ; 3rd trigger point of demo
0763   018A D8                                 RET     C                   ; return if greater
0764   018B 06 FE                              LD      B,$FE               ; 1111_1110...push fire
0765   018D 2D                                 DEC     L                   ;
0766   018E 7E                                 LD      A,(HL)              ; get $4398 (MSB from 16 bit counter)
0767   018F FE 09                              CP      $09                 ; 4rd trigger point of demo
0768   0191 C0                                 RET     NZ                  ; return if not equal
0769   0192 06 7E                              LD      B,$7E               ; 0111_1110...push shield
0770   0194 C9                                 RET                         ;
0771   0195             
0772   0196                                    .ORG $0196
0773   0196             ;*****************************************************************************
0774   0196             ;* Slow printing the static texts for the score average table 
0775   0196             ;* and the big letters of phoenix title.
0776   0196             ;*****************************************************************************
0777   0196             SlowPrintScoreAverageTable:
0778   0196 7E                                 LD      A,(HL)              ; get actual index for slow print ($4399)
0779   0197 E6 1F                              AND     $1F                 ; mask out 0001_1111
0780   0199 FE 06                              CP      $06                 ; reached state 6 ?
0781   019B D8                                 RET     C                   ; no..return
0782   019C 5F                                 LD      E,A                 ; save the state
0783   019D 7E                                 LD      A,(HL)              ; get actual index for slow print ($4399)
0784   019E E6 E0                              AND     $E0                 ; mask out 1110_0000
0785   01A0 4F                                 LD      C,A                 ; save bits 5,6,7
0786   01A1 2D                                 DEC     L                   ;
0787   01A2 46                                 LD      B,(HL)              ; get zero reference from $4398
0788   01A3 2E A8                              LD      L,$A8               ; ..and..
0789   01A5 70                                 LD      (HL),B              ; save it to $43A8
0790   01A6 2C                                 INC     L                   ;
0791   01A7 71                                 LD      (HL),C              ; save bits 5,6,7 to $43A9
0792   01A8 01 60 18                           LD      BC,T1860            ; data block starting with 'INSERT  COIN' text
0793   01AB CD 06 02                           CALL    AddBCtoMem          ; stores MSB LSB
0794   01AE 7E                                 LD      A,(HL)              ;
0795   01AF 2D                                 DEC     L                   ;
0796   01B0 66                                 LD      H,(HL)              ;
0797   01B1 6F                                 LD      L,A                 ;
0798   01B2 7B                                 LD      A,E                 ;
0799   01B3 56                                 LD      D,(HL)              ; get the data
0800   01B4 2C                                 INC     L                   ;
0801   01B5 5E                                 LD      E,(HL)              ;
0802   01B6 2D                                 DEC     L                   ;
0803   01B7 4F                                 LD      C,A                 ;
0804   01B8 85                                 ADD     A,L                 ;
0805   01B9 6F                                 LD      L,A                 ;
0806   01BA 79                                 LD      A,C                 ;
0807   01BB D6 06                              SUB     $06                 ;
0808   01BD 4F                                 LD      C,A                 ;
0809   01BE CA C8 01                           JP      Z,L01C8             ;
0810   01C1             L01C1:
0811   01C1 CD 17 02                           CALL    RightOneColumn      ; move to next screen position
0812   01C4 0D                                 DEC     C                   ;
0813   01C5 C2 C1 01                           JP      NZ,L01C1            ;
0814   01C8             L01C8:
0815   01C8 7E                                 LD      A,(HL)              ;
0816   01C9 12                                 LD      (DE),A              ; print one character on the screen
0817   01CA C3 E0 14                           JP      L14E0               ; check for coin event
0818   01CD             
0819   01D0                                    .ORG $01D0
0820   01D0             ;*****************************************************************************
0821   01D0             ;* Print the top 3 lines (scores, lives, coins)
0822   01D0             ;*****************************************************************************
0823   01D0             PrintTextLines:
0824   01D0 56                                 LD      D,(HL)              ; Get ...
0825   01D1 2C                                 INC     L                   ; ... the ...
0826   01D2 5E                                 LD      E,(HL)              ; ... screen coord
0827   01D3 7D                                 LD      A,L                 ; Add 5 ...
0828   01D4 C6 05                              ADD     $05                 ; ... go get ...
0829   01D6 6F                                 LD      L,A                 ; ... data
0830   01D7 06 1A                              LD      B,$1A               ; 26 columns
0831   01D9 CD ED 01                           CALL    DrawRow             ; Draw next row
0832   01DC 0D                                 DEC     C                   ; All lines done?
0833   01DD C2 D0 01                           JP      NZ,PrintTextLines   ; No ... draw all rows
0834   01E0 C9                                 RET                         ; Done
0835   01E1             
0836   01E1             ;*****************************************************************************
0837   01E1             ;* Print the copyright lines (bottom 3 lines)
0838   01E1             ;*****************************************************************************
0839   01E1             PrintCopyright:
0840   01E1 CD 40 01                           CALL    ClearForeAndBackground
0841   01E4             L01E4:
0842   01E4 21 60 19                           LD      HL,T1960            ; "PHOENIX ... U.S.A"
0843   01E7 0E 03                              LD      C,$03               ; 3 lines at the bottom
0844   01E9 C3 D0 01                           JP      PrintTextLines      ; Print the copyright
0845   01EC             
0846   01ED                                    .ORG $01ED
0847   01ED             ;*****************************************************************************
0848   01ED             ;* Remember the screen is rotated.
0849   01ED             ;* This draws a column in screen memory (row on the screen)
0850   01ED             ;*****************************************************************************
0851   01ED             DrawRow:
0852   01ED 7E                                 LD      A,(HL)              ; Copy the data ...
0853   01EE 12                                 LD      (DE),A              ; .. to the screen
0854   01EF 23                                 INC     HL                  ; Next in data
0855   01F0 CD 17 02                           CALL    RightOneColumn      ; Move DE to next row
0856   01F3 05                                 DEC     B                   ; All drawn?
0857   01F4 C2 ED 01                           JP      NZ,DrawRow          ; Draw them all
0858   01F7 C9                                 RET                         ; Done
0859   01F8             
0860   0200                                    .ORG $0200
0861   0200             ;*****************************************************************************
0862   0200             ;* Two-byte +1 to (HL-1) : (HL).
0863   0200             ;*****************************************************************************
0864   0200             AddOneToMem:
0865   0200 34                                 INC     (HL)                ; Add one to LSB
0866   0201 C0                                 RET     NZ                  ; We didn't overflow ... done
0867   0202 2D                                 DEC     L                   ; Back up to MSB
0868   0203 34                                 INC     (HL)                ; Carry into the MSB
0869   0204 2C                                 INC     L                   ; Restore point to LSB
0870   0205 C9                                 RET                         ; Done
0871   0206             
0872   0206             ;*****************************************************************************
0873   0206             ;* Two-byte addition. BC is added to (HL-1) : (HL).
0874   0206             ;*****************************************************************************
0875   0206             AddBCtoMem:
0876   0206 7E                                 LD      A,(HL)              ; Get the lower byte
0877   0207 81                                 ADD     A,C                 ; Add C to the lower
0878   0208 77                                 LD      (HL),A              ; Store the new lower
0879   0209 2D                                 DEC     L                   ; Back up to upper byte
0880   020A 7E                                 LD      A,(HL)              ; Add B and carry ...
0881   020B 88                                 ADC     A,B                 ; ... to upper byte
0882   020C 77                                 LD      (HL),A              ; Store the new upper byte
0883   020D 2C                                 INC     L                   ; Restore pointer to LSB
0884   020E C9                                 RET                         ; Done
0885   020F             
0886   0210                                    .ORG $0210
0887   0210             ;*****************************************************************************
0888   0210             ;* Add 32 (left one column on the rotated screen) to DE (two bytes)
0889   0210             ;*****************************************************************************
0890   0210             LeftOneColumn:
0891   0210 7B                                 LD      A,E                 ; Add ...
0892   0211 C6 20                              ADD     $20                 ; ... 32 to ...
0893   0213 5F                                 LD      E,A                 ; ... E
0894   0214 D0                                 RET     NC                  ; No carry ... we are done
0895   0215 14                                 INC     D                   ; Carry into D
0896   0216 C9                                 RET                         ; Done
0897   0217             
0898   0217             ;*****************************************************************************
0899   0217             ;* Subtract 32 (right one column on the rotated screen) from DE (two bytes)
0900   0217             ;*****************************************************************************
0901   0217             RightOneColumn:
0902   0217 7B                                 LD      A,E                 ; Subtract ...
0903   0218 D6 20                              SUB     $20                 ; ... 32 from ...
0904   021A 5F                                 LD      E,A                 ; ... E
0905   021B D0                                 RET     NC                  ; No borrow ... we are done
0906   021C 15                                 DEC     D                   ; Borrow from D
0907   021D C9                                 RET                         ; Done
0908   021E             
0909   0220                                    .ORG $0220
0910   0220             ;*****************************************************************************
0911   0220             ;* 3-byte (6 digit) BCD addition. Add BC*10 to (HL-2):(HL-1):(HL).
0912   0220             ;* The games keeps the lowest digit of the scores to 0.
0913   0220             ;*****************************************************************************
0914   0220             AddToScore:
0915   0220 AF                                 XOR     A                   ; !! Pointless. We are about to change A and the flags
0916   0221 7E                                 LD      A,(HL)              ; Lowest 2 digits
0917   0222 81                                 ADD     A,C                 ; Add C to score
0918   0223 27                                 DAA                         ; Adjust for binary coded decimal
0919   0224 77                                 LD      (HL),A              ; Update lowest 2 digits
0920   0225 2D                                 DEC     L                   ; Point to middle 2 digits
0921   0226 7E                                 LD      A,(HL)              ; Add B to ...
0922   0227 88                                 ADC     A,B                 ; ... score
0923   0228 27                                 DAA                         ; Adjust for BCD
0924   0229 77                                 LD      (HL),A              ; Store the middle 2 digits
0925   022A 2D                                 DEC     L                   ; Point to the upper 2 digits
0926   022B 7E                                 LD      A,(HL)              ; Add in ...
0927   022C CE 00                              ADC     $00                 ; ... any carry
0928   022E 27                                 DAA                         ; Adjust for binary coded decimal
0929   022F 77                                 LD      (HL),A              ; Store the upper 2 digits
0930   0230 2C                                 INC     L                   ; Restore ...
0931   0231 2C                                 INC     L                   ; ... pointer
0932   0232 C9                                 RET                         ; Done
0933   0233             
0934   0258                                    .ORG $0258
0935   0258             ;*****************************************************************************
0936   0258             ;* Two byte compare of BC to memory at (HL-1):(HL)
0937   0258             ;*****************************************************************************
0938   0258             CompareBCtoMem:
0939   0258 7E                                 LD      A,(HL)              ; Value from memory
0940   0259 B9                                 CP      C                   ; Are the lower values the same?
0941   025A C0                                 RET     NZ                  ; No ... return not-zero
0942   025B 2D                                 DEC     L                   ; Point to MSB
0943   025C 7E                                 LD      A,(HL)              ; Get the MSB value
0944   025D 2C                                 INC     L                   ; Restore the pointer
0945   025E B8                                 CP      B                   ; Compare the MSBs
0946   025F C9                                 RET                         ; Return the flags
0947   0260             
0948   0260             ;*****************************************************************************
0949   0260             ;* Subtract DE from memory if memory is greater/equal to BC.
0950   0260             ;*****************************************************************************
0951   0260             SubtractIfEnough:
0952   0260 CD 70 02                           CALL    SubtractFromMemory  ; Try subtraction. Is memory larger (or equal) to BC?
0953   0263 D8                                 RET     C                   ; No ... ignore request
0954   0264 CD 77 02                           CALL    SubtractToMemory    ; Yes ... subtract DE from memory
0955   0267 C9                                 RET                         ; Done
0956   0268             
0957   0270                                    .ORG $0270
0958   0270             ;*****************************************************************************
0959   0270             ;* Two byte subtraction of memory from BC. BC = BC -  (HL-1):(HL)
0960   0270             ;*****************************************************************************
0961   0270             SubtractFromMemory:
0962   0270 7E                                 LD      A,(HL)              ; Get the low byte
0963   0271 91                                 SUB     C                   ; Subtract from C
0964   0272 2D                                 DEC     L                   ; Point to upper byte
0965   0273 7E                                 LD      A,(HL)              ; Get the upper byte
0966   0274 98                                 SBC     B                   ; Subtract from B (with borrow)
0967   0275 2C                                 INC     L                   ; Restore pointer
0968   0276 C9                                 RET                         ; Done
0969   0277             
0970   0277             ;*****************************************************************************
0971   0277             ;* Two byte subtraction of DE from memory. (HL-1):(HL) = (HL-1):(HL) - DE
0972   0277             ;*****************************************************************************
0973   0277             SubtractToMemory:
0974   0277 7B                                 LD      A,E                 ; Lower byte
0975   0278 96                                 SUB     (HL)                ; Subtract it from memory
0976   0279 2D                                 DEC     L                   ; Point to upper byte
0977   027A 7A                                 LD      A,D                 ; Value to A
0978   027B 9E                                 SBC     (HL)                ; Subtract upper byte from memory (with borrow)
0979   027C 2C                                 INC     L                   ; Restore pointer
0980   027D C9                                 RET                         ; Done
0981   027E             
0982   0280                                    .ORG $0280
0983   0280             ;*****************************************************************************
0984   0280             ;* Two byte compare of HL to BC
0985   0280             ;*****************************************************************************
0986   0280             CompareHLtoBC:
0987   0280 7D                                 LD      A,L                 ; Compare lower ...
0988   0281 B9                                 CP      C                   ; ... bytes
0989   0282 C0                                 RET     NZ                  ; Not the same ... return NZ
0990   0283 7C                                 LD      A,H                 ; Compare upper ...
0991   0284 B8                                 CP      B                   ; ... bytes
0992   0285 C9                                 RET                         ; Return the check
0993   0286             
0994   0288                                    .ORG $0288
0995   0288             ;*****************************************************************************
0996   0288             ;* Start game screen
0997   0288             ;*****************************************************************************
0998   0288             PromptForStartGame:
0999   0288 CD 40 01                           CALL    ClearForeAndBackground
1000   028B 21 C0 19                           LD      HL,T19C0            ; 
1001   028E 0E 02                              LD      C,$02               ; print two lines: 'PUSH ONLY...1PLAYER BUTTON'
1002   0290 CD D0 01                           CALL    PrintTextLines      ;
1003   0293 0E 02                              LD      C,$02               ;
1004   0295 CD E0 17                           CALL    CoinChecking        ;
1005   0298 FE 02                              CP      $02                 ; 2 player mode possible if credit > 1
1006   029A DA A7 02                           JP      C,L02A7             ;
1007   029D 21 A0 1B                           LD      HL,T1BA0            ;
1008   02A0 0E 01                              LD      C,$01               ; print one line: '1 OR 2PLAYERS BUTTON'
1009   02A2 CD D0 01                           CALL    PrintTextLines      ;
1010   02A5 0E 06                              LD      C,$06               ;
1011   02A7             L02A7:
1012   02A7 3A 00 70                           LD      A,(IN0)             ; 70xx IN0  Get the bits...
1013   02AA 2F                                 CPL                         ; ...for the two...
1014   02AB A1                                 AND     C                   ; ...start buttons and...
1015   02AC C8                                 RET     Z                   ; ...ret if no start button was pressed.
1016   02AD CD CB 02                           CALL    DecrementCoins      ; (GameOrAttract will be affected here as well)
1017   02B0 CD F0 02                           CALL    UpdateHiScore       ;
1018   02B3 CD 2E 03                           CALL    ClearAndPrintScores ;
1019   02B6 CD 50 03                           CALL    GetPlayerLivesFromDip
1020   02B9 CD 40 01                           CALL    ClearForeAndBackground
1021   02BC 26 50                              LD      H,videoRegister >> 8
1022   02BE 36 01                              LD      (HL),$01            ;
1023   02C0 CD 40 01                           CALL    ClearForeAndBackground
1024   02C3 26 50                              LD      H,videoRegister >> 8
1025   02C5 36 00                              LD      (HL),$00            ;
1026   02C7 C9                                 RET                         ;
1027   02C8             
1028   02CB                                    .ORG $02CB
1029   02CB             ;*****************************************************************************
1030   02CB             ;* Coin handling
1031   02CB             ;*****************************************************************************
1032   02CB             DecrementCoins:
1033   02CB 0E 01                              LD      C,$01               ; Value for 'one player game mode'
1034   02CD FE 02                              CP      $02                 ; A register holds the value of start buttons
1035   02CF CA D4 02                           JP      Z,L02D4             ; jump if 'start 1' was pressed.
1036   02D2 0E 02                              LD      C,$02               ; Value for 'two players game mode'
1037   02D4             L02D4:
1038   02D4 21 A2 43                           LD      HL,GameOrAttract    ; 
1039   02D7 71                                 LD      (HL),C              ; set it to 1 or 2 and leave the attract mode.
1040   02D8 3A 00 78                           LD      A,(DSW0)            ; 78xx DSW0
1041   02DB E6 10                              AND     $10                 ; mask for coinage 0001_0000
1042   02DD CA E3 02                           JP      Z,L02E3             ;
1043   02E0 79                                 LD      A,C                 ;
1044   02E1 07                                 RLCA                        ; Multiply by 2
1045   02E2 4F                                 LD      C,A                 ;
1046   02E3             L02E3:
1047   02E3 2E 8F                              LD      L,CoinCount & $FF   ; LSB of CoinCount
1048   02E5 7E                                 LD      A,(HL)              ; get CoinCount value
1049   02E6 91                                 SUB     C                   ; decrement coins
1050   02E7 77                                 LD      (HL),A              ; save it
1051   02E8 C6 20                              ADD     $20                 ; map value to character code
1052   02EA 32 42 41                           LD      (ForegroundScreen+$142),A ; updates the number of coins on the screen
1053   02ED C9                                 RET                         ;
1054   02EE             
1055   02F0                                    .ORG $02F0
1056   02F0             ;*****************************************************************************
1057   02F0             ;* Copy the score to hi score if greater
1058   02F0             ;*****************************************************************************
1059   02F0             UpdateHiScore:
1060   02F0 11 83 43                           LD      DE,Score1low        ; score of player 1
1061   02F3 21 8B 43                           LD      HL,HiScorelow       ; current hi score
1062   02F6 CD 14 03                           CALL    L0314               ;
1063   02F9 D4 20 03                           CALL    NC,L0320            ;
1064   02FC 1E 87                              LD      E,Score2low & $FF   ; LSB of Score2low
1065   02FE 2E 8B                              LD      L,HiScorelow & $FF  ; LSB of HiScorelow
1066   0300 CD 14 03                           CALL    L0314               ;
1067   0303 D4 20 03                           CALL    NC,L0320            ;
1068   0306 2E 8B                              LD      L,HiScorelow & $FF  ; LSB of HiScorelow
1069   0308 11 41 41                           LD      DE,$4141            ; High-score Screen coordinates (LSB)
1070   030B 06 06                              LD      B,$06               ; 6 digits
1071   030D CD C4 00                           CALL    PrintNumber         ; Print the 6-digit number
1072   0310 C9                                 RET                         ; Done
1073   0311             
1074   0314                                    .ORG $0314
1075   0314             L0314:
1076   0314 1A                                 LD      A,(DE)              ;
1077   0315 96                                 SUB     (HL)                ;
1078   0316 1D                                 DEC     E                   ;
1079   0317 2D                                 DEC     L                   ;
1080   0318 1A                                 LD      A,(DE)              ;
1081   0319 9E                                 SBC     (HL)                ;
1082   031A 1D                                 DEC     E                   ;
1083   031B 2D                                 DEC     L                   ;
1084   031C 1A                                 LD      A,(DE)              ;
1085   031D 9E                                 SBC     (HL)                ;
1086   031E C9                                 RET                         ;
1087   031F             
1088   0320                                    .ORG $0320
1089   0320             L0320:
1090   0320 1A                                 LD      A,(DE)              ;
1091   0321 77                                 LD      (HL),A              ;
1092   0322 13                                 INC     DE                  ;
1093   0323 23                                 INC     HL                  ;
1094   0324 1A                                 LD      A,(DE)              ;
1095   0325 77                                 LD      (HL),A              ;
1096   0326 13                                 INC     DE                  ;
1097   0327 23                                 INC     HL                  ;
1098   0328 1A                                 LD      A,(DE)              ;
1099   0329 77                                 LD      (HL),A              ;
1100   032A C9                                 RET                         ;
1101   032B             
1102   032E                                    .ORG $032E
1103   032E             ;*****************************************************************************
1104   032E             ;* Update of the score values on screen.
1105   032E             ;*****************************************************************************
1106   032E             ClearAndPrintScores:
1107   032E 21 80 43                           LD      HL,M4380            ; Clear scores..
1108   0331             L0331:
1109   0331 36 00                              LD      (HL),$00            ; ..from $4380..
1110   0333 23                                 INC     HL                  ;
1111   0334 7D                                 LD      A,L                 ;
1112   0335 FE 88                              CP      $88                 ; ..to $4387
1113   0337 C2 31 03                           JP      NZ,L0331            ;
1114   033A 2E 83                              LD      L,Score1low & $FF   ; print player 1 score
1115   033C 11 61 42                           LD      DE,$4261            ; Score1 screen coordinates (LSB)
1116   033F 06 06                              LD      B,$06               ; 6 digits
1117   0341 CD C4 00                           CALL    PrintNumber         ;
1118   0344 2E 87                              LD      L,Score2low & $FF   ; print player 2 score
1119   0346 11 21 40                           LD      DE,$4021            ; Score2 screen coordinates (LSB)
1120   0349 06 06                              LD      B,$06               ; 6 digits
1121   034B CD C4 00                           CALL    PrintNumber         ;
1122   034E C9                                 RET                         ; Done
1123   034F             
1124   0350                                    .ORG $0350
1125   0350             ;*****************************************************************************
1126   0350             ;* Gets the DIP switch settings for player lives.
1127   0350             ;*****************************************************************************
1128   0350             GetPlayerLivesFromDip:
1129   0350 3A 00 78                           LD      A,(DSW0)            ; 78xx DSW0, get DIP switch settings
1130   0353 E6 03                              AND     $03                 ; mask out 0000_0011 number of lives
1131   0355 C6 03                              ADD     $03                 ; to get : 03, 04, 05 or 06
1132   0357 47                                 LD      B,A                 ;
1133   0358 21 90 43                           LD      HL,Player1Lives     ;
1134   035B 70                                 LD      (HL),B              ; save it
1135   035C 2E A2                              LD      L,GameOrAttract & $FF
1136   035E 7E                                 LD      A,(HL)              ; load GameOrAttract and ..
1137   035F FE 01                              CP      $01                 ; check if one or two players mode
1138   0361 CA 67 03                           JP      Z,UpdateLivesScreen ;
1139   0364 2E 91                              LD      L,Player2Lives & $FF
1140   0366 70                                 LD      (HL),B              ; save it to Player2Lives
1141   0367             
1142   0367             ;*****************************************************************************
1143   0367             ;* Updates the number of lives on the screen
1144   0367             ;*****************************************************************************
1145   0367             UpdateLivesScreen:
1146   0367 2E 90                              LD      L,Player1Lives & $FF
1147   0369 7E                                 LD      A,(HL)              ; load Player1Lives
1148   036A F6 20                              OR      $20                 ; map value to character code
1149   036C 32 A2 42                           LD      (ForegroundScreen+$2A2),A ; number of lives, for player 1 at screen ram
1150   036F 2C                                 INC     L                   ;
1151   0370 7E                                 LD      A,(HL)              ; load Player2Lives
1152   0371 F6 20                              OR      $20                 ; map value to character code
1153   0373 32 62 40                           LD      (ForegroundScreen+$62),A ; number of lives, for player 2 at screen ram
1154   0376 C9                                 RET                         ;
1155   0377             
1156   0377             ;*****************************************************************************
1157   0377             ;* Update the sound control RAM registers
1158   0377             ;*****************************************************************************
1159   0377             UpdateSoundControlRAM:
1160   0377 21 8C 43                           LD      HL,SoundControlA    ;
1161   037A 77                                 LD      (HL),A              ;
1162   037B 2C                                 INC     L                   ; and update ..
1163   037C 77                                 LD      (HL),A              ; .. SoundControlB
1164   037D C9                                 RET                         ;
1165   037E             
1166   0380                                    .ORG $0380
1167   0380             ;*****************************************************************************
1168   0380             ;* Clears the foreground except for the top 3 rows (the scores)
1169   0380             ;*****************************************************************************
1170   0380             ClearForeground:
1171   0380 21 3F 43                           LD      HL,ForegroundScreen+$33F       ; End of foreground screen
1172   0383 11 1F 00                           LD      DE,$001F            ; 00 for clear and 1F for finding end of a column
1173   0386 01 3F 03                           LD      BC,$033F            ; 03 for leaving top 3 rows and 3F for find the beginning of screen memory
1174   0389             L0389:
1175   0389 72                                 LD      (HL),D              ; Clear the screen
1176   038A 2B                                 DEC     HL                  ; Next location
1177   038B 72                                 LD      (HL),D              ; Clear the screen
1178   038C 2B                                 DEC     HL                  ; Next location
1179   038D 7D                                 LD      A,L                 ; Keep lower 5 ...
1180   038E A3                                 AND     E                   ; ... bits (32 bytes in a column)
1181   038F B8                                 CP      B                   ; At the top of the column?
1182   0390 C2 89 03                           JP      NZ,L0389            ; No ... keep clearing the column
1183   0393 72                                 LD      (HL),D              ; Clear the 4th column from the top
1184   0394 2B                                 DEC     HL                  ; To ...
1185   0395 2B                                 DEC     HL                  ; ... top ...
1186   0396 2B                                 DEC     HL                  ; ... of the ...
1187   0397 2B                                 DEC     HL                  ; ... row
1188   0398 7C                                 LD      A,H                 ; Have we reached ...
1189   0399 B9                                 CP      C                   ; ... 3FFF ?
1190   039A C2 89 03                           JP      NZ,L0389            ; No ... clear all columns
1191   039D C9                                 RET                         ; Done
1192   039E             
1193   03A0                                    .ORG $03A0
1194   03A0             ;*****************************************************************************
1195   03A0             ;* Clears the background screen.
1196   03A0             ;*****************************************************************************
1197   03A0             ClearBackground:
1198   03A0 21 3F 4B                           LD      HL,BackgroundScreen+$33F       ; End of background screen memory
1199   03A3 11 47 00                           LD      DE,$0047            ; 00 for clear and 47 to find the beginning of screen memory
1200   03A6             L03A6:
1201   03A6 72                                 LD      (HL),D              ; Clear the screen
1202   03A7 2B                                 DEC     HL                  ; Next location
1203   03A8 72                                 LD      (HL),D              ; Clear the screen
1204   03A9 2B                                 DEC     HL                  ; Next location
1205   03AA 7C                                 LD      A,H                 ; Have we reached ...
1206   03AB BB                                 CP      E                   ; HL = 47FF ?
1207   03AC C2 A6 03                           JP      NZ,L03A6            ; No ... keep clearing
1208   03AF C9                                 RET                         ; Done
1209   03B0             
1210   03B0             ;*****************************************************************************
1211   03B0             ;* The game demo is using the real game code with simulated player inputs.
1212   03B0             ;* The timeline of the game demo, as part of the attract mode,
1213   03B0             ;* is covered by a 16 bit counter $4398:$4399.
1214   03B0             ;* 1st demo from value: $03E6 to $07A0.
1215   03B0             ;* 2nd demo from value: $0800 to $0B60.
1216   03B0             ;* 3rd demo from value: $0C00 to $1510.
1217   03B0             ;*****************************************************************************
1218   03B0             GameDemo:
1219   03B0 01 A0 07                           LD      BC,$07A0            ;
1220   03B3 CD 70 02                           CALL    SubtractFromMemory  ;
1221   03B6 DA CE 03                           JP      C,L03CE             ;
1222   03B9 CD 58 02                           CALL    CompareBCtoMem      ;
1223   03BC CA EB 03                           JP      Z,L03EB             ;
1224   03BF 01 60 0B                           LD      BC,$0B60            ;
1225   03C2 CD 70 02                           CALL    SubtractFromMemory  ;
1226   03C5 DA CE 03                           JP      C,L03CE             ;
1227   03C8 CD 58 02                           CALL    CompareBCtoMem      ;
1228   03CB CA E2 03                           JP      Z,L03E2             ;
1229   03CE             L03CE:
1230   03CE CD 73 01                           CALL    GetPlayerInputsForDemo
1231   03D1 21 A0 43                           LD      HL,IN0Current       ;
1232   03D4 7E                                 LD      A,(HL)              ;
1233   03D5 E6 01                              AND     $01                 ; mask out real button presses, but leave the coin event.
1234   03D7 B0                                 OR      B                   ; feed the IN0Current with movement data
1235   03D8 77                                 LD      (HL),A              ; for the game demo.
1236   03D9 C3 00 04                           JP      GameStateMachine    ;
1237   03DC             
1238   03E2                                    .ORG $03E2
1239   03E2             ;*****************************************************************************
1240   03E2             ;* Changing the game demo level at attract mode.
1241   03E2             ;*****************************************************************************
1242   03E2             L03E2:
1243   03E2 01 08 01                           LD      BC,$0108            ; Next interval game state is 1, set LevelAndRound to 1st round, level 8 (mothership wave)
1244   03E5 11 00 10                           LD      DE,$1000            ; set AliensLeft to 1 and BirdsLeft to 0 ?
1245   03E8 C3 F1 03                           JP      L03F1               ; 
1246   03EB             
1247   03EB             ;*****************************************************************************
1248   03EB             ;* Changing the game demo level at attract mode.
1249   03EB             ;*****************************************************************************
1250   03EB             L03EB:
1251   03EB 01 04 01                           LD      BC,$0104            ;
1252   03EE 11 08 00                           LD      DE,$0008            ;
1253   03F1             L03F1:
1254   03F1 21 A4 43                           LD      HL,GameState        ; Next interval game state ...
1255   03F4 70                                 LD      (HL),B              ; ... is 1 (flashing of score)
1256   03F5 2E B8                              LD      L,$B8               ;
1257   03F7 71                                 LD      (HL),C              ; set LevelAndRound to 1st round, level 4 (blue birds wave)
1258   03F8 2E BA                              LD      L,$BA               ;
1259   03FA 72                                 LD      (HL),D              ; set AliensLeft to 0
1260   03FB 2C                                 INC     L                   ;
1261   03FC 73                                 LD      (HL),E              ; set BirdsLeft to 8
1262   03FD C9                                 RET                         ;
1263   03FE             
1264   0400                                    .ORG $0400
1265   0400             ;*****************************************************************************
1266   0400             ;* Game state machine.
1267   0400             ;* Jump to function by number in GameState.
1268   0400             ;*****************************************************************************
1269   0400             GameStateMachine:
1270   0400 21 0E 04                           LD      HL,T040E            ; Jump table
1271   0403 3A A4 43                           LD      A,(GameState)       ;
1272   0406 07                                 RLCA                        ; *2
1273   0407 85                                 ADD     A,L                 ; Offset ...
1274   0408 6F                                 LD      L,A                 ; ... into the table
1275   0409 7E                                 LD      A,(HL)              ; MSB of destination
1276   040A 2C                                 INC     L                   ; Get the
1277   040B 6E                                 LD      L,(HL)              ; ... LSB of destination
1278   040C 67                                 LD      H,A                 ; Now point to function
1279   040D E9                                 JP      (HL)                ; Jump to function
1280   040E             
1281   040E             ; Notice these addresses are MSB:LSB (backwards from the processor's endianness)
1282   040E             T040E:
1283   040E                                    .MSFIRST
1284   040E 04 30                              .DW L0430                   ; game state 0: called once at 'new game start'
1285   0410 04 AC                              .DW L04AC                   ; game state 1: called for each frame during 'flashing of score1 or 2'
1286   0412 05 15                              .DW L0515                   ; game state 2: called once for initialization of game and level data
1287   0414 08 00                              .DW L0800                   ; game state 3: called for each frame of normal game play
1288   0416 0A EA                              .DW L0AEA                   ; game state 4: called for each frame of 'player ship partikel explosion'
1289   0418 0B 60                              .DW L0B60                   ; game state 5: called for each frame during 'GAME OVER' text
1290   041A 24 00                              .DW L2400                   ; game state 6: called for each frame during 'mother ship partikel explosion'
1291   041C 24 4C                              .DW L244C                   ; game state 7: called for each frame during 'mother ship score display'
1292   041E             
1293   041E             ;*****************************************************************************
1294   041E             ;* Set lower bits of video register,
1295   041E             ;* for the color palette, memory bank, and the screen flipping at cocktail mode.
1296   041E             ;*****************************************************************************
1297   041E             SetBitsVideoRegister:
1298   041E 3A A3 43                           LD      A,(GameAndDemoOrSplash)
1299   0421 E6 01                              AND     $01                 ; mask out 0000_0001 for 'memory bank'
1300   0423 47                                 LD      B,A                 ;
1301   0424 3A B8 43                           LD      A,(LevelAndRound)   ;
1302   0427 E6 02                              AND     $02                 ; masc out 0000_0010 for 'color palette'
1303   0429 B0                                 OR      B                   ; set the bits at...
1304   042A 32 00 50                           LD      (videoRegister),A   ; 50xx video register
1305   042D C9                                 RET                         ;
1306   042E             
1307   0430                                    .ORG $0430
1308   0430             ;*****************************************************************************
1309   0430             ;* Game state 0.
1310   0430             ;* New game start.
1311   0430             ;*****************************************************************************
1312   0430             L0430:
1313   0430 21 A4 43                           LD      HL,GameState        ; Next interval game state ...
1314   0433 36 01                              LD      (HL),$01            ; ... is 1 (flashing of score)
1315   0435 2C                                 INC     L                   ;
1316   0436 36 80                              LD      (HL),$80            ; Set value for CounterA5 (score flash time)
1317   0438 2E A3                              LD      L,GameAndDemoOrSplash & $FF   ; save the value of..
1318   043A 7E                                 LD      A,(HL)              ; .. GameAndDemoOrSplash
1319   043B 36 00                              LD      (HL),$00            ; set it to game demo / game play
1320   043D FE 02                              CP      $02                 ;
1321   043F C8                                 RET     Z                   ; return if it was 'Intro splash' before.
1322   0440 77                                 LD      (HL),A              ; set GameAndDemoOrSplash to 'Game and demo for player 1'
1323   0441 2D                                 DEC     L                   ;
1324   0442 7E                                 LD      A,(HL)              ; get GameOrAttract
1325   0443 FE 01                              CP      $01                 ;
1326   0445 C8                                 RET     Z                   ; return if 'One player game mode'
1327   0446 2C                                 INC     L                   ;
1328   0447 7E                                 LD      A,(HL)              ; get GameAndDemoOrSplash
1329   0448 A7                                 AND     A                   ; updates the zero flag
1330   0449 CA A0 04                           JP      Z,L04A0             ; if 'Game and demo'
1331   044C 2E 90                              LD      L,$90               ;
1332   044E 7E                                 LD      A,(HL)              ; get Player1Lives
1333   044F A7                                 AND     A                   ; updates the zero flag
1334   0450 C8                                 RET     Z                   ; return if no lives left.
1335   0451 2E A3                              LD      L,$A3               ;
1336   0453 36 00                              LD      (HL),$00            ; set GameAndDemoOrSplash to 'Game and demo for player 1'
1337   0455 01 00 01                           LD      BC,$0100            ; from bank 1 to bank 0
1338   0458 CD 60 04                           CALL    CopyMemoryBank      ; to toggle the player
1339   045B C9                                 RET                         ;
1340   045C             
1341   0460                                    .ORG $0460
1342   0460             ;*****************************************************************************
1343   0460             ;* Copy memory bank to bank
1344   0460             ;* B=from bank number, C=to bank number
1345   0460             ;* Starts at 4320
1346   0460             ;*****************************************************************************
1347   0460             CopyMemoryBank:
1348   0460 21 00 50                           LD      HL,videoRegister    ; 50xx video register
1349   0463 11 20 43                           LD      DE,ForegroundScreen+$320; 1st row 1st line
1350   0466             L0466:
1351   0466 70                                 LD      (HL),B              ;
1352   0467 1A                                 LD      A,(DE)              ;
1353   0468 71                                 LD      (HL),C              ;
1354   0469 12                                 LD      (DE),A              ;
1355   046A 1C                                 INC     E                   ;
1356   046B 7B                                 LD      A,E                 ;
1357   046C E6 03                              AND     $03                 ;
1358   046E C2 66 04                           JP      NZ,L0466            ;
1359   0471 7B                                 LD      A,E                 ;
1360   0472 E6 F0                              AND     $F0                 ;
1361   0474 D6 20                              SUB     $20                 ;
1362   0476 5F                                 LD      E,A                 ;
1363   0477 D2 66 04                           JP      NC,L0466            ;
1364   047A 15                                 DEC     D                   ;
1365   047B 7A                                 LD      A,D                 ;
1366   047C FE 3F                              CP      $3F                 ;
1367   047E C2 66 04                           JP      NZ,L0466            ;
1368   0481 11 80 43                           LD      DE,M4380            ;
1369   0484             L0484:
1370   0484 70                                 LD      (HL),B              ;
1371   0485 1A                                 LD      A,(DE)              ;
1372   0486 71                                 LD      (HL),C              ;
1373   0487 12                                 LD      (DE),A              ;
1374   0488 1C                                 INC     E                   ;
1375   0489 7B                                 LD      A,E                 ;
1376   048A FE B8                              CP      $B8                 ;
1377   048C C2 84 04                           JP      NZ,L0484            ;
1378   048F 11 C0 4B                           LD      DE,M4BC0            ;
1379   0492             L0492:
1380   0492 70                                 LD      (HL),B              ;
1381   0493 1A                                 LD      A,(DE)              ;
1382   0494 71                                 LD      (HL),C              ;
1383   0495 12                                 LD      (DE),A              ;
1384   0496 1C                                 INC     E                   ;
1385   0497 7B                                 LD      A,E                 ;
1386   0498 FE 00                              CP      $00                 ;
1387   049A C2 92 04                           JP      NZ,L0492            ;
1388   049D C9                                 RET                         ;
1389   049E             
1390   04A0                                    .ORG $04A0
1391   04A0             ;*****************************************************************************
1392   04A0             ;* Changing the player at attract mode.
1393   04A0             ;*****************************************************************************
1394   04A0             L04A0:
1395   04A0 2E A3                              LD      L,$A3               ; set GameAndDemoOrSplash
1396   04A2 36 01                              LD      (HL),$01            ; to 'Game for player 2'
1397   04A4 01 01 00                           LD      BC,$0001            ; from bank 0 to bank 1
1398   04A7 CD 60 04                           CALL    CopyMemoryBank      ; to toggle the player
1399   04AA C9                                 RET                         ;
1400   04AB             
1401   04AC                                    .ORG $04AC
1402   04AC             ;*****************************************************************************
1403   04AC             ;* Game state 1.
1404   04AC             ;* Flashing of score1 or 2.
1405   04AC             ;*****************************************************************************
1406   04AC             L04AC:
1407   04AC 21 A5 43                           LD      HL,CounterA5        ;
1408   04AF 35                                 DEC     (HL)                ; decrement counter
1409   04B0 7E                                 LD      A,(HL)              ; save value
1410   04B1 2D                                 DEC     L                   ; HL=A3A4 next game state ..
1411   04B2 36 02                              LD      (HL),$02            ; .. is 2
1412   04B4 A7                                 AND     A                   ; ret if ..
1413   04B5 C8                                 RET     Z                   ; counter 0
1414   04B6 36 01                              LD      (HL),$01            ; set game state to 1
1415   04B8 FE 7F                              CP      $7F                 ; 0111_1111
1416   04BA CA F0 07                           JP      Z,L07F0             ;
1417   04BD 2E 9A                              LD      L,$9A               ;
1418   04BF 36 00                              LD      (HL),$00            ; reset Counter9A MSB
1419   04C1 2C                                 INC     L                   ; and ..
1420   04C2 36 00                              LD      (HL),$00            ; LSB
1421   04C4 E6 08                              AND     $08                 ; 0000_1000
1422   04C6 C2 E6 04                           JP      NZ,L04E6            ;
1423   04C9 CD E8 06                           CALL    L06E8               ;
1424   04CC 00                                 NOP                         ;
1425   04CD 21 A3 43                           LD      HL,GameAndDemoOrSplash
1426   04D0 7E                                 LD      A,(HL)              ;
1427   04D1 A7                                 AND     A                   ; updates the zero flag
1428   04D2 2E 83                              LD      L,$83               ; LSB of Score1low adress
1429   04D4 11 61 42                           LD      DE,$4261            ; screen ram addr. of lowest score digit player 1
1430   04D7 CA DF 04                           JP      Z,L04DF             ; 
1431   04DA 2E 87                              LD      L,$87               ; LSB of Score2low adress
1432   04DC 11 21 40                           LD      DE,$4021            ; screen ram addr. of lowest score digit player 2
1433   04DF             L04DF:
1434   04DF 06 06                              LD      B,$06               ; number of digits to print
1435   04E1 CD C4 00                           CALL    PrintNumber         ;
1436   04E4 C9                                 RET                         ;
1437   04E5             
1438   04E6                                    .ORG $04E6
1439   04E6             L04E6:
1440   04E6 21 A3 43                           LD      HL,GameAndDemoOrSplash
1441   04E9 7E                                 LD      A,(HL)              ;
1442   04EA A7                                 AND     A                   ; updates the zero flag
1443   04EB 11 61 42                           LD      DE,$4261            ; screen ram addr. of lowest score digit player 1
1444   04EE CA F4 04                           JP      Z,L04F4             ;
1445   04F1 11 21 40                           LD      DE,$4021            ; screen ram addr. of lowest score digit player 2
1446   04F4             L04F4:
1447   04F4 06 06                              LD      B,$06               ; number of digits to delete
1448   04F6 CD FB 04                           CALL    L04FB               ;
1449   04F9 C9                                 RET                         ;
1450   04FA             
1451   04FB                                    .ORG $04FB
1452   04FB             L04FB:
1453   04FB 3E 00                              LD      A,$00               ; delete ..
1454   04FD 12                                 LD      (DE),A              ; ..one digit
1455   04FE CD 10 02                           CALL    LeftOneColumn       ;
1456   0501 05                                 DEC     B                   ; decrement number of digits
1457   0502 C2 FB 04                           JP      NZ,L04FB            ; ..until
1458   0505 C9                                 RET                         ; ..done
1459   0506             
1460   0506             ;*****************************************************************************
1461   0506             ;* Clear $4392 to $4397 and
1462   0506             ;* init start value list pointer for alien movement MSB $4394
1463   0506             ;*****************************************************************************
1464   0506             L0506:
1465   0506 21 92 43                           LD      HL,M4392            ;
1466   0509 06 06                              LD      B,$06               ; number of bytes to clear
1467   050B CD D8 05                           CALL    ClearBbytesAtHL     ;
1468   050E 3A 50 4B                           LD      A,(M4B50)           ;
1469   0511 32 94 43                           LD      (M4394),A           ;
1470   0514 C9                                 RET                         ;
1471   0515             
1472   0515             ;*****************************************************************************
1473   0515             ;* Game state 2.
1474   0515             ;* Initialization of game and level data.
1475   0515             ;*****************************************************************************
1476   0515             L0515:
1477   0515 CD 1E 04                           CALL    SetBitsVideoRegister; set color palette according to LevelAndRound
1478   0518 21 A4 43                           LD      HL,GameState        ; Next interval game state ...
1479   051B 36 03                              LD      (HL),$03            ; ... is 3 (normal game play)
1480   051D CD 80 05                           CALL    InitGlobalLevelData ;
1481   0520 CD 47 05                           CALL    InitPlayerDataStructure
1482   0523 CD A0 09                           CALL    L09A0               ; get screen ram adress for player ship position
1483   0526             L0526:
1484   0526 CD 32 05                           CALL    L0532               ; init alien data for a new level and round
1485   0529 CD 6C 0A                           CALL    L0A6C               ; get screen ram adress for all aliens
1486   052C CD 06 05                           CALL    L0506               ; clear 4392 to 4397, init 4394
1487   052F C3 B0 32                           JP      L32B0               ;
1488   0532             
1489   0532             ;*****************************************************************************
1490   0532             ;* Init alien data for a new level and round
1491   0532             ;*****************************************************************************
1492   0532             L0532:
1493   0532 21 50 4B                           LD      HL,M4B50            ;
1494   0535 06 A0                              LD      B,$A0               ; clear $4B50 to $4BEF
1495   0537 CD D8 05                           CALL    ClearBbytesAtHL     ;
1496   053A CD EC 05                           CALL    InitAlienControlStates
1497   053D CD 50 06                           CALL    L0650               ; copy init values for 16 aliens to $4B50-$4B6F
1498   0540 CD 10 06                           CALL    InitAlienPositions  ; load alien screen coordinates (X,Y grid), for a new level and round
1499   0543 C9                                 RET                         ;
1500   0544             
1501   0547                                    .ORG $0547
1502   0547             ;*****************************************************************************
1503   0547             ;* Copy 32 byte from $0560 to $43C0 Player and bullets data structure (grid)
1504   0547             ;* and clear 32 bytes of player and bullets data structure (screen ram).
1505   0547             ;*****************************************************************************
1506   0547             InitPlayerDataStructure:
1507   0547 21 60 05                           LD      HL,T0560            ;
1508   054A 11 C0 43                           LD      DE,PlayerState      ; base of data structure (grid)
1509   054D 06 20                              LD      B,$20               ;
1510   054F CD E0 05                           CALL    CopyBbytesHLtoDE    ;
1511   0552 21 E0 43                           LD      HL,OldPlayerShipMSB ;
1512   0555 06 20                              LD      B,$20               ;
1513   0557 CD D8 05                           CALL    ClearBbytesAtHL     ;
1514   055A C9                                 RET                         ;
1515   055B             
1516   0560                                    .ORG $0560
1517   0560             ; Data copied to $43C0-$43DF
1518   0560             ; Default values for player and bullets data structure (grid).
1519   0560             T0560:
1520   0560 0C 10 64 D8                        .DB $0C, $10, $64, $D8       ; PlayerState, PlayerShape, PlayerShipX, PlayerShipY
1521   0564 00 50 00 D0                        .DB $00, $50, $00, $D0       ; PlayerBulletState, PlayerBulletShape, PlayerBulletX, PlayerBulletY
1522   0568 00 50 00 D0                        .DB $00, $50, $00, $D0       ; AbovePlayerBulletState, AbovePlayerBulletShape, AbovePlayerBulletX, AbovePlayerBulletY
1523   056C 00 58 00 20                        .DB $00, $58, $00, $20       ; AlienBullet0State, AlienBullet0Shape, AlienBullet0X, AlienBullet0Y
1524   0570 00 58 00 20                        .DB $00, $58, $00, $20       ; AlienBullet1State, AlienBullet1Shape, AlienBullet1X, AlienBullet1Y
1525   0574 00 58 00 20                        .DB $00, $58, $00, $20       ; AlienBullet2State, AlienBullet2Shape, AlienBullet2X, AlienBullet2Y
1526   0578 00 58 00 20                        .DB $00, $58, $00, $20       ; AlienBullet3State, AlienBullet3Shape, AlienBullet3X, AlienBullet3Y
1527   057C 00 58 00 20                        .DB $00, $58, $00, $20       ; AlienBullet4State, AlienBullet4Shape, AlienBullet4X, AlienBullet4Y
1528   0580             
1529   0580             ;*****************************************************************************
1530   0580             ;* Init of global level data, dependent on level and round.
1531   0580             ;*****************************************************************************
1532   0580             InitGlobalLevelData:
1533   0580 21 98 05                           LD      HL,T0598            ;
1534   0583 3A B8 43                           LD      A,(LevelAndRound)   ;
1535   0586 E6 0F                              AND     $0F                 ;
1536   0588 85                                 ADD     A,L                 ;
1537   0589 6F                                 LD      L,A                 ;
1538   058A 6E                                 LD      L,(HL)              ;
1539   058B 26 05                              LD      H,$05               ;
1540   058D 11 AB 43                           LD      DE,M43AB            ;
1541   0590 06 0C                              LD      B,$0C               ; number of bytes to copy
1542   0592 CD E0 05                           CALL    CopyBbytesHLtoDE    ;
1543   0595 C9                                 RET                         ;
1544   0596             
1545   0598                                    .ORG $0598
1546   0598             ; Table for the global level data, over game levels.
1547   0598             ; Bit0 - bit3 of $43B8 is the table index.
1548   0598             ; Data will be fetched two times. Once before and once after the 'spiral fill' animation.
1549   0598             T0598:
1550   0598 A8 A8                              .DB T05A8 & $FF, T05A8 & $FF    ;init values for 1st alien wave (pointer to $05A8, $05A8)
1551   059A C0 C0                              .DB T05C0 & $FF, T05C0 & $FF    ;init values for 2st alien wave (pointer to $05C0, $05C0)
1552   059C A8 A8                              .DB T05A8 & $FF, T05A8 & $FF    ;init values for blue birds wave (pointer to $05A8, $05A8)
1553   059E A8 A8                              .DB T05A8 & $FF, T05A8 & $FF    ;init values for pink birds wave (pointer to $05A8, $05A8)
1554   05A0 B4 CC                              .DB T05B4 & $FF, T05CC & $FF    ;init values for mothership wave (pointer to $05B4, $05CC)
1555   05A2 B4 B4                              .DB T05B4 & $FF, T05B4 & $FF    ;init values for mothership wave (pointer to $05B4, $05B4)
1556   05A4 A8 A8                              .DB T05A8 & $FF, T05A8 & $FF    ;not used? pointer to $05A8, $05A8
1557   05A6 A8 A8                              .DB T05A8 & $FF, T05A8 & $FF    ;not used? pointer to $05A8, $05A8
1558   05A8             ;
1559   05A8             ; e.g.:counter values, timer values, T1C00, T1D00, T1F00, ..
1560   05A8             ; Data copied to $43AB-$43B6
1561   05A8             T05A8:
1562   05A8 80 7F 00 00                        .DB $80, $7F, $00, $00, $40, $3F, $00, T1C00 >> 8, T1C00 & $FF, $FF, $FF, $FF
1562   05AC 40 3F 00 1C 
1562   05B0 00 FF FF FF 
1563   05B4             T05B4:
1564   05B4 60 5F 01 02                        .DB $60, $5F, $01, $02, $30, $2F, $00, T1C00 >> 8, T1C00 & $FF, $C0, $FF, $FF
1564   05B8 30 2F 00 1C 
1564   05BC 00 C0 FF FF 
1565   05C0             T05C0:
1566   05C0 80 7F 03 04                        .DB $80, $7F, $03, $04, $40, $3F, $00, T1F00 >> 8, T1F00 & $FF, $A0, $FF, $FF
1566   05C4 40 3F 00 1F 
1566   05C8 00 A0 FF FF 
1567   05CC             T05CC:
1568   05CC 60 60 05 06                        .DB $60, $60, $05, $06, $50, $30, $00, T1D00 >> 8, T1D00 & $FF, $48, $FF, $FF
1568   05D0 50 30 00 1D 
1568   05D4 00 48 FF FF 
1569   05D8             
1570   05D8             ;*****************************************************************************
1571   05D8             ;* Clears B memories starting at HL.
1572   05D8             ;*****************************************************************************
1573   05D8             ClearBbytesAtHL:
1574   05D8 AF                                 XOR     A                   ; A=0
1575   05D9             L05D9:
1576   05D9 77                                 LD      (HL),A              ; store
1577   05DA 23                                 INC     HL                  ; next
1578   05DB 05                                 DEC     B                   ; decrease counter.
1579   05DC C2 D9 05                           JP      NZ,L05D9            ;
1580   05DF C9                                 RET                         ;
1581   05E0             
1582   05E0             ;*****************************************************************************
1583   05E0             ;* Copy number of bytes (B register) from DE to HL.
1584   05E0             ;*****************************************************************************
1585   05E0             CopyBbytesHLtoDE:
1586   05E0 7E                                 LD      A,(HL)              ; Copy to HL ...
1587   05E1 12                                 LD      (DE),A              ; ... from DE
1588   05E2 23                                 INC     HL                  ; Next destination
1589   05E3 13                                 INC     DE                  ; Next source
1590   05E4 05                                 DEC     B                   ; All done?
1591   05E5 C2 E0 05                           JP      NZ,CopyBbytesHLtoDE ; no ... keep going
1592   05E8 C9                                 RET                         ; Out
1593   05E9             
1594   05EC                                    .ORG $05EC
1595   05EC             ;*****************************************************************************
1596   05EC             ;* Init all alien control states for a given level and round.
1597   05EC             ;*****************************************************************************
1598   05EC             InitAlienControlStates:
1599   05EC 21 00 15                           LD      HL,T1500            ;
1600   05EF 3A B8 43                           LD      A,(LevelAndRound)   ;
1601   05F2 E6 0F                              AND     $0F                 ;
1602   05F4 07                                 RLCA                        ; Multiply by 2
1603   05F5 85                                 ADD     A,L                 ;
1604   05F6 6F                                 LD      L,A                 ;
1605   05F7 56                                 LD      D,(HL)              ;
1606   05F8 23                                 INC     HL                  ;
1607   05F9 5E                                 LD      E,(HL)              ;
1608   05FA             ;
1609   05FA             L05FA:
1610   05FA 21 70 4B                           LD      HL,M4B70            ;
1611   05FD 3A BA 43                           LD      A,(AliensLeft)      ;
1612   0600 47                                 LD      B,A                 ;
1613   0601 A7                                 AND     A                   ; updates the zero flag
1614   0602 C8                                 RET     Z                   ; if no AliensLeft
1615   0603             ;
1616   0603             L0603:
1617   0603 72                                 LD      (HL),D              ; set control state A
1618   0604 2C                                 INC     L                   ;
1619   0605 73                                 LD      (HL),E              ; set control state B
1620   0606 2C                                 INC     L                   ;
1621   0607 2C                                 INC     L                   ;
1622   0608 2C                                 INC     L                   ;
1623   0609 05                                 DEC     B                   ; number of aliens left
1624   060A C2 03 06                           JP      NZ,L0603            ;
1625   060D C9                                 RET                         ;
1626   060E             
1627   0610                                    .ORG $0610
1628   0610             ;*****************************************************************************
1629   0610             ;* Load alien screen coordinates for a given level and round to $4B70 - $4BAF.
1630   0610             ;*****************************************************************************
1631   0610             InitAlienPositions:
1632   0610 21 3A 06                           LD      HL,T063A            ;
1633   0613 3A B8 43                           LD      A,(LevelAndRound)   ;
1634   0616 0F                                 RRCA                        ;
1635   0617 E6 0F                              AND     $0F                 ; mask out 0000_1111
1636   0619 85                                 ADD     A,L                 ;
1637   061A 6F                                 LD      L,A                 ;
1638   061B 00                                 NOP                         ; Old command removed or space for a future replace patch
1639   061C 00                                 NOP                         ; ..
1640   061D 00                                 NOP                         ; ..
1641   061E 6E                                 LD      L,(HL)              ;
1642   061F 26 15                              LD      H,T1540 >> 8        ; MSB for T1540-T15E0
1643   0621 11 72 4B                           LD      DE,M4B72            ;
1644   0624 3A BA 43                           LD      A,(AliensLeft)      ;
1645   0627 47                                 LD      B,A                 ;
1646   0628 A7                                 AND     A                   ; updates the zero flag
1647   0629 C8                                 RET     Z                   ; if no AliensLeft
1648   062A             ;
1649   062A             L062A:
1650   062A 7E                                 LD      A,(HL)              ; get value from table
1651   062B 12                                 LD      (DE),A              ; save to alien screen coordinate
1652   062C 23                                 INC     HL                  ;
1653   062D 13                                 INC     DE                  ;
1654   062E 7E                                 LD      A,(HL)              ;
1655   062F 12                                 LD      (DE),A              ;
1656   0630 23                                 INC     HL                  ;
1657   0631 13                                 INC     DE                  ;
1658   0632 13                                 INC     DE                  ;
1659   0633 13                                 INC     DE                  ;
1660   0634 05                                 DEC     B                   ;
1661   0635 C2 2A 06                           JP      NZ,L062A            ; loop for all AliensLeft
1662   0638 C9                                 RET                         ;
1663   0639             
1664   063A                                    .ORG $063A
1665   063A             ; Init data for 1st game round.
1666   063A             ; LSB's for T1560, T1540, T15E0.
1667   063A             T063A:
1668   063A 60 40 E0 E0                        .DB T1560 & $FF, T1540 & $FF, T15E0 & $FF, T15E0 & $FF, T15E0 & $FF, T15E0 & $FF, $FF, $FF
1668   063E E0 E0 FF FF 
1669   0642             ; Init data for 2nd game round.
1670   0642             ; LSB's for T15C0, T15A0, T1580.
1671   0642 C0 A0 80 80                        .DB T15C0 & $FF, T15A0 & $FF, T1580 & $FF, T1580 & $FF, T1580 & $FF, T1580 & $FF, $FF, $FF
1671   0646 80 80 FF FF 
1672   064A             
1673   0650                                    .ORG $0650
1674   0650             ;*****************************************************************************
1675   0650             ;* Copy init values for 16 aliens to $4B50-$4B6F (Pointer to alien movement pattern)
1676   0650             ;*****************************************************************************
1677   0650             L0650:
1678   0650 21 20 15                           LD      HL,T1520            ;
1679   0653 3A B8 43                           LD      A,(LevelAndRound)   ;
1680   0656 E6 0F                              AND     $0F                 ; mask out 0000_1111
1681   0658 07                                 RLCA                        ; Multiply by 2
1682   0659 85                                 ADD     A,L                 ;
1683   065A 6F                                 LD      L,A                 ;
1684   065B 56                                 LD      D,(HL)              ;
1685   065C 23                                 INC     HL                  ;
1686   065D 5E                                 LD      E,(HL)              ;
1687   065E 21 50 4B                           LD      HL,M4B50            ;
1688   0661 3A BA 43                           LD      A,(AliensLeft)      ;
1689   0664 47                                 LD      B,A                 ;
1690   0665 A7                                 AND     A                   ; updates the zero flag
1691   0666 C8                                 RET     Z                   ; if no AliensLeft
1692   0667             L0667:
1693   0667 72                                 LD      (HL),D              ;
1694   0668 2C                                 INC     L                   ;
1695   0669 73                                 LD      (HL),E              ;
1696   066A 2C                                 INC     L                   ;
1697   066B 05                                 DEC     B                   ;
1698   066C C2 67 06                           JP      NZ,L0667            ; loop for all AliensLeft
1699   066F C9                                 RET                         ;
1700   0670             
1701   067A                                    .ORG $067A
1702   067A             ;*****************************************************************************
1703   067A             ;* Scroll down the background screen one pixel.
1704   067A             ;*****************************************************************************
1705   067A             StarsScrollDown:
1706   067A 21 B9 43                           LD      HL,CounterB9        ;
1707   067D 7E                                 LD      A,(HL)              ;
1708   067E 35                                 DEC     (HL)                ; decrement the backwards counter
1709   067F 32 00 58                           LD      (scrollRegister),A  ; 58xx scroll register
1710   0682 E6 07                              AND     $07                 ; mask out 0000_0111
1711   0684 C0                                 RET     NZ                  ; continue after 8 pixels...
1712   0685             ; Fill the background with stars or mothership.
1713   0685 01 47 20                           LD      BC,$2047            ;
1714   0688 11 21 4B                           LD      DE,$4B21            ; get character from the background screen (1st row, 2nd line)
1715   068B 7E                                 LD      A,(HL)              ; get $43B9 free running 8 bit backwards counter value
1716   068C 0F                                 RRCA                        ;
1717   068D 0F                                 RRCA                        ;
1718   068E 0F                                 RRCA                        ;
1719   068F E6 1F                              AND     $1F                 ; mask out 0001_1111
1720   0691 83                                 ADD     A,E                 ;
1721   0692 5F                                 LD      E,A                 ;
1722   0693 2E B2                              LD      L,$B2               ;
1723   0695 7E                                 LD      A,(HL)              ; get $43B2 (MSB of T1C00 or T1D00 or T1F00)
1724   0696 2C                                 INC     L                   ;
1725   0697 6E                                 LD      L,(HL)              ; get $43B3 (LSB of T1C00 or T1D00 or T1F00)
1726   0698 67                                 LD      H,A                 ;
1727   0699             L0699:
1728   0699 7E                                 LD      A,(HL)              ;
1729   069A 12                                 LD      (DE),A              ; to background screen
1730   069B 2C                                 INC     L                   ;
1731   069C 7B                                 LD      A,E                 ;
1732   069D 90                                 SUB     B                   ;
1733   069E 5F                                 LD      E,A                 ;
1734   069F D2 99 06                           JP      NC,L0699            ;
1735   06A2 15                                 DEC     D                   ;
1736   06A3 7A                                 LD      A,D                 ;
1737   06A4 B9                                 CP      C                   ;
1738   06A5 C2 99 06                           JP      NZ,L0699            ;
1739   06A8 7D                                 LD      A,L                 ;
1740   06A9 32 B3 43                           LD      (M43B3),A           ;
1741   06AC C9                                 RET                         ;
1742   06AD             
1743   06B0                                    .ORG $06B0
1744   06B0             ;*****************************************************************************
1745   06B0             ;* Fill the background with (2x2) planets.
1746   06B0             ;*****************************************************************************
1747   06B0             AddPlanetsToBackground:
1748   06B0 21 AB 43                           LD      HL,M43AB            ; counter value for (2x2) planets
1749   06B3 3A B9 43                           LD      A,(CounterB9)       ;
1750   06B6 4F                                 LD      C,A                 ;
1751   06B7 BE                                 CP      (HL)                ;
1752   06B8 C0                                 RET     NZ                  ;
1753   06B9 7E                                 LD      A,(HL)              ;
1754   06BA 2C                                 INC     L                   ;
1755   06BB 86                                 ADD     A,(HL)              ;
1756   06BC 2D                                 DEC     L                   ;
1757   06BD 77                                 LD      (HL),A              ;
1758   06BE 2C                                 INC     L                   ;
1759   06BF 2C                                 INC     L                   ;
1760   06C0 34                                 INC     (HL)                ;
1761   06C1 46                                 LD      B,(HL)              ;
1762   06C2 2C                                 INC     L                   ;
1763   06C3 34                                 INC     (HL)                ;
1764   06C4 7E                                 LD      A,(HL)              ;
1765   06C5 21 20 1E                           LD      HL,T1E20            ; MSB's of screen ram for planets
1766   06C8 E6 1F                              AND     $1F                 ;
1767   06CA 85                                 ADD     A,L                 ;
1768   06CB 6F                                 LD      L,A                 ;
1769   06CC 56                                 LD      D,(HL)              ;
1770   06CD C6 20                              ADD     $20                 ;
1771   06CF 6F                                 LD      L,A                 ;
1772   06D0 5E                                 LD      E,(HL)              ;
1773   06D1 79                                 LD      A,C                 ;
1774   06D2 0F                                 RRCA                        ;
1775   06D3 0F                                 RRCA                        ;
1776   06D4 0F                                 RRCA                        ;
1777   06D5 E6 1E                              AND     $1E                 ;
1778   06D7 83                                 ADD     A,E                 ;
1779   06D8 C6 02                              ADD     $02                 ;
1780   06DA 5F                                 LD      E,A                 ;
1781   06DB 21 60 1E                           LD      HL,T1E60            ; LSB's of screen ram for planets
1782   06DE 78                                 LD      A,B                 ;
1783   06DF E6 1F                              AND     $1F                 ;
1784   06E1 85                                 ADD     A,L                 ;
1785   06E2 6F                                 LD      L,A                 ;
1786   06E3 6E                                 LD      L,(HL)              ;
1787   06E4 CD DC 07                           CALL    L07DC               ; draw the characters at background
1788   06E7 C9                                 RET                         ;
1789   06E8             
1790   06E8             ;*****************************************************************************
1791   06E8             ;* Print score column
1792   06E8             ;*****************************************************************************
1793   06E8             L06E8:
1794   06E8 21 00 18                           LD      HL,T1800            ; base addr. table for 'screen ram adresses and static texts'
1795   06EB 0E 01                              LD      C,$01               ; 1 column (rotated to 1 row)
1796   06ED C3 D0 01                           JP      PrintTextLines      ;
1797   06F0             
1798   06F0             ;*****************************************************************************
1799   06F0             ;* Update scroll register and fill background
1800   06F0             ;*****************************************************************************
1801   06F0             L06F0:
1802   06F0 CD 7A 06                           CALL    StarsScrollDown     ;
1803   06F3 CD 40 20                           CALL    AddGalaxiesToBackground
1804   06F6 C3 B0 06                           JP      AddPlanetsToBackground
1805   06F9             
1806   0700                                    .ORG $0700
1807   0700             ;*****************************************************************************
1808   0700             ;* Controller for player data structure.
1809   0700             ;* Handles: PlayerState, OldPlayerShipMSB, PlayerBulletState, PlayerBulletMSB, AbovePlayerBulletState, $43E8
1810   0700             ;*****************************************************************************
1811   0700             PlayerDataController:
1812   0700 01 C0 43                           LD      BC,PlayerState      ; Player data structure (grid)
1813   0703 11 E0 43                           LD      DE,OldPlayerShipMSB ; Player data structure (screen ram)
1814   0706             L0706:
1815   0706 CD 18 07                           CALL    UpdateScreenObjects ;
1816   0709 79                                 LD      A,C                 ;
1817   070A C6 04                              ADD     $04                 ;
1818   070C 4F                                 LD      C,A                 ;
1819   070D C6 20                              ADD     $20                 ;
1820   070F 5F                                 LD      E,A                 ;
1821   0710 50                                 LD      D,B                 ;
1822   0711 FE EC                              CP      $EC                 ;
1823   0713 C2 06 07                           JP      NZ,L0706            ; loop until $43EC
1824   0716 C9                                 RET                         ;
1825   0717             
1826   0718                                    .ORG $0718
1827   0718             ;*****************************************************************************
1828   0718             ;* Draw or delete screen objects dep. on control state of player, alien and bullet.
1829   0718             ;*****************************************************************************
1830   0718             UpdateScreenObjects:
1831   0718 CD 20 07                           CALL    Bit4Controller      ; for deleting screen objects
1832   071B C3 40 07                           JP      Bit3Controller      ; for drawing screen objects
1833   071E             
1834   0720                                    .ORG $0720
1835   0720             ;*****************************************************************************
1836   0720             ;* Handles the bit4 actions for deleting screen objects.
1837   0720             ;*****************************************************************************
1838   0720             Bit4Controller:
1839   0720 0A                                 LD      A,(BC)              ; get value from data structure (grid)
1840   0721 67                                 LD      H,A                 ; save the bits
1841   0722 E6 10                              AND     $10                 ; mask out 0001_0000 (bit4 of control state A)
1842   0724 C8                                 RET     Z                   ; ret if bit not set.
1843   0725 7C                                 LD      A,H                 ; restore the bits
1844   0726 E6 EF                              AND     $EF                 ; mask out 1110_1111
1845   0728 02                                 LD      (BC),A              ; save to control state A
1846   0729 07                                 RLCA                        ; Multiply by 8 ..
1847   072A 07                                 RLCA                        ; ..
1848   072B 07                                 RLCA                        ; ..
1849   072C E6 07                              AND     $07                 ; mask out 0000_0111
1850   072E C6 38                              ADD     $38                 ; add to base for jump table
1851   0730 6F                                 LD      L,A                 ;
1852   0731 26 07                              LD      H,T0735 >> 8        ; MSB for jump table
1853   0733 6E                                 LD      L,(HL)              ;
1854   0734 E9                                 JP      (HL)                ; jump to control function
1855   0735             
1856   0735             ; LSB jump table:
1857   0735             ;.....not used
1858   0735             ;........not used
1859   0735             ;...........not used
1860   0735             ;..............0763..................control state A: 0001_xxxx...Delete 1x1 screen objects.
1861   0735             ;.................0779...............control state A: 0011_xxxx...Delete 2x1 screen objects.
1862   0735             ;....................not used
1863   0735             ;.......................079E.........control state A: 0111_xxxx...Delete 1x2 screen objects.
1864   0735             ;..........................07BE......control state A: 1001_xxxx...Delete 2x2 screen objects.
1865   0735             T0735:
1866   0735 00 00 00 63                        .DB $00, $00, $00, L0763 & $FF, L0779 & $FF, $00, L079E & $FF, L07BE & $FF
1866   0739 79 00 9E BE 
