2230   08C4             ;*****************************************************************************
2231   08C4             ;* Player ship, shield and bullets handler.
2232   08C4             ;*****************************************************************************
2233   08C4             MovePlayer:
2234   08C4 21 C0 43                           LD      HL,PlayerState      ;
2235   08C7 7E                                 LD      A,(HL)              ;
2236   08C8 E6 08                              AND     $08                 ; mask out 0000_1000
2237   08CA CA A0 0A                           JP      Z,DrawShields       ; Draw shields
2238   08CD 2E A6                              LD      L,$A6               ;
2239   08CF 7E                                 LD      A,(HL)              ; get ShieldCount
2240   08D0 A7                                 AND     A                   ; updates the zero flag
2241   08D1 C2 EA 08                           JP      NZ,L08EA            ; if ShieldCount not 0.
2242   08D4 06 80                              LD      B,$80               ; 1000_0000 (bit7='shield')
2243   08D6 CD BB 00                           CALL    CheckInputBits      ;
2244   08D9 CA EB 08                           JP      Z,L08EB             ;
2245   08DC 2E 62                              LD      L,$62               ;
2246   08DE 36 40                              LD      (HL),$40            ; set bit6 at $4362
2247   08E0 2E C0                              LD      L,$C0               ;
2248   08E2 7E                                 LD      A,(HL)              ; get $43C0 PlayerState
2249   08E3 E6 F7                              AND     $F7                 ; mask out 1111_0111
2250   08E5 77                                 LD      (HL),A              ;
2251   08E6 2E A6                              LD      L,$A6               ;
2252   08E8 36 FF                              LD      (HL),$FF            ;
2253   08EA             L08EA:
2254   08EA 35                                 DEC     (HL)                ; decrement ShieldCount
2255   08EB             L08EB:
2256   08EB 2E C2                              LD      L,PlayerShipX & $FF ; LSB of $43C2 PlayerShipX
2257   08ED CD 00 09                           CALL    L0900               ; Update the player ship x coordinate.
2258   08F0 01 00 16                           LD      BC,T1600            ;
2259   08F3 C3 26 09                           JP      L0926               ; get player ship animation frame values, mapped with T1600/T1620
2260   08F6             
2261   0900                                    .ORG $0900
2262   0900             ;*****************************************************************************
2263   0900             ;* Update the player ship x coordinate.
2264   0900             ;*****************************************************************************
2265   0900             L0900:
2266   0900 3A A0 43                           LD      A,(IN0Current)      ;
2267   0903 2F                                 CPL                         ; flip the current bits
2268   0904 E6 60                              AND     $60                 ; mask out 0110_0000
2269   0906 C8                                 RET     Z                   ; if no button pressed
2270   0907 E6 40                              AND     $40                 ; mask out 0100_0000
2271   0909 CA 17 09                           JP      Z,L0917             ;
2272   090C 7E                                 LD      A,(HL)              ; get $43C2 PlayerShipX
2273   090D FE 0D                              CP      $0D                 ;
2274   090F D8                                 RET     C                   ; if left boundary reached
2275   0910 35                                 DEC     (HL)                ; 'left' button: dec $43C2 PlayerShipX
2276   0911 3E FF                              LD      A,$FF               ;
2277   0913 32 60 43                           LD      (PlayerMoved),A     ; set 'player moved' flag
2278   0916 C9                                 RET                         ;
2279   0917             L0917:
2280   0917 7E                                 LD      A,(HL)              ; get $43C2 PlayerShipX
2281   0918 FE C0                              CP      $C0                 ;
2282   091A D0                                 RET     NC                  ; if right boundary reached
2283   091B 34                                 INC     (HL)                ; 'right' button: inc $43C2 PlayerShipX
2284   091C 3E FF                              LD      A,$FF               ;
2285   091E 32 60 43                           LD      (PlayerMoved),A     ; set 'player moved' flag
2286   0921 C9                                 RET                         ;
