1868   0740                                    .ORG $0740
1869   0740             ;*****************************************************************************
1870   0740             ;* Handles the bit3 actions for drawing screen objects.
1871   0740             ;*****************************************************************************
1872   0740             Bit3Controller:
1873   0740 0A                                 LD      A,(BC)              ; get value from data structure (grid)
1874   0741 67                                 LD      H,A                 ; save it
1875   0742 E6 08                              AND     $08                 ; mask out 0000_1000 (bit3 of control state A)
1876   0744 C8                                 RET     Z                   ; ret if bit not set.
1877   0745 7C                                 LD      A,H                 ; restore the bits
1878   0746 E6 07                              AND     $07                 ; mask out 0000_0111
1879   0748 67                                 LD      H,A                 ; save it
1880   0749 0F                                 RRCA                        ; Divide by 8 ..
1881   074A 0F                                 RRCA                        ; ..
1882   074B 0F                                 RRCA                        ; ..
1883   074C B4                                 OR      H                   ; add original bits
1884   074D F6 18                              OR      $18                 ; set 0001_1000 flag
1885   074F 02                                 LD      (BC),A              ; set the bits at control state A
1886   0750 03                                 INC     BC                  ; go to control state B
1887   0751 7C                                 LD      A,H                 ;
1888   0752 C6 5B                              ADD     $5B                 ; add to base for jump table
1889   0754 6F                                 LD      L,A                 ;
1890   0755 26 07                              LD      H,T0759 >> 8        ; MSB for jump table
1891   0757 6E                                 LD      L,(HL)              ;
1892   0758 E9                                 JP      (HL)                ; jump to control function
1893   0759             
1894   0759             ; LSB jump table:
1895   0759             ;.....not used
1896   0759             ;........not used
1897   0759             ;...........076D.....................control state A: xxxx_1000...Draw 1x1 screen objects.
1898   0759             ;..............0788..................control state A: xxxx_1001...Draw 2x1 screen objects.
1899   0759             ;.................not used
1900   0759             ;....................07AA............control state A: xxxx_1011...Draw 1x2 screen objects.
1901   0759             ;.......................07D2.........control state A: xxxx_1100...Draw 2x2 screen objects.
1902   0759             ;..........................not used
1903   0759             T0759:
1904   0759 00 00 6D 88                        .DB $00, $00, L076D & $FF, L0788 & $FF, $00, L07AA & $FF, L07D2 & $FF
1904   075D 00 AA D2 
1905   0760             
1906   0763                                    .ORG $0763
1907   0763             ;*****************************************************************************
1908   0763             ;* Bit4 control function 63:
1909   0763             ;* If control state A: 0001_xxxx
1910   0763             ;* Delete 1x1 screen objects (bullet, alien).
1911   0763             ;*****************************************************************************
1912   0763             L0763:
1913   0763 EB                                 EX      DE,HL               ;
1914   0764 56                                 LD      D,(HL)              ; get screen ram adress MSB
1915   0765 23                                 INC     HL                  ;
1916   0766 5E                                 LD      E,(HL)              ; get screen ram adress LSB
1917   0767 2B                                 DEC     HL                  ; restore pointer
1918   0768 AF                                 XOR     A                   ; A=0
1919   0769 12                                 LD      (DE),A              ; delete at screen
1920   076A EB                                 EX      DE,HL               ;
1921   076B C9                                 RET                         ;
1922   076C             
1923   076D                                    .ORG $076D
1924   076D             ;*****************************************************************************
1925   076D             ;* Bit3 control function 6D:
1926   076D             ;* If control state A: xxxx_1000
1927   076D             ;* Set alien control state B value to screen ram.
1928   076D             ;* Draw 1x1 screen objects (used at 'fade in' animation).
1929   076D             ;*****************************************************************************
1930   076D             L076D:
1931   076D EB                                 EX      DE,HL               ;
1932   076E 23                                 INC     HL                  ;
1933   076F 23                                 INC     HL                  ;
1934   0770 56                                 LD      D,(HL)              ; get MSB screen ram adress of alien
1935   0771 23                                 INC     HL                  ;
1936   0772 5E                                 LD      E,(HL)              ; get LSB screen ram adress of alien
1937   0773 0A                                 LD      A,(BC)              ; get alien control state B
1938   0774 12                                 LD      (DE),A              ; set at screen ram
1939   0775 0B                                 DEC     BC                  ; move to alien control state A
1940   0776 C9                                 RET                         ;
1941   0777             
1942   0779                                    .ORG $0779
1943   0779             ;*****************************************************************************
1944   0779             ;* Bit4 control function 79:
1945   0779             ;* If control state A: 0011_xxxx
1946   0779             ;* Delete 2x1 screen objects (alien).
1947   0779             ;*****************************************************************************
1948   0779             L0779:
1949   0779 EB                                 EX      DE,HL               ;
1950   077A 56                                 LD      D,(HL)              ;
1951   077B 23                                 INC     HL                  ;
1952   077C 5E                                 LD      E,(HL)              ;
1953   077D 2B                                 DEC     HL                  ; restore pointer
1954   077E AF                                 XOR     A                   ; A=0
1955   077F 12                                 LD      (DE),A              ; delete at screen, left part
1956   0780 CD 17 02                           CALL    RightOneColumn      ; 
1957   0783 AF                                 XOR     A                   ; A=0
1958   0784 12                                 LD      (DE),A              ; delete at screen, right part
1959   0785 EB                                 EX      DE,HL               ;
1960   0786 C9                                 RET                         ;
1961   0787             
1962   0788                                    .ORG $0788
1963   0788             ;*****************************************************************************
1964   0788             ;* Bit3 control function 88:
1965   0788             ;* If control state A: xxxx_1001
1966   0788             ;* Map alien control state B to shape and draw it.
1967   0788             ;* Draw 2x1 screen objects (alien).
1968   0788             ;*****************************************************************************
1969   0788             L0788:
1970   0788 EB                                 EX      DE,HL               ;
1971   0789 23                                 INC     HL                  ;
1972   078A 23                                 INC     HL                  ;
1973   078B 56                                 LD      D,(HL)              ;
1974   078C 23                                 INC     HL                  ;
1975   078D 5E                                 LD      E,(HL)              ;
1976   078E 0A                                 LD      A,(BC)              ; get alien control state B
1977   078F 6F                                 LD      L,A                 ; as offset for...
1978   0790 26 14                              LD      H,T1420 >> 8        ; get alien character block shapes table
1979   0792 7E                                 LD      A,(HL)              ;
1980   0793 12                                 LD      (DE),A              ; draw alien character left part
1981   0794 23                                 INC     HL                  ; next character
1982   0795 CD 17 02                           CALL    RightOneColumn      ;
1983   0798 7E                                 LD      A,(HL)              ;
1984   0799 12                                 LD      (DE),A              ; draw alien character right part
1985   079A 0B                                 DEC     BC                  ;
1986   079B C9                                 RET                         ;
1987   079C             
1988   079E                                    .ORG $079E
1989   079E             ;*****************************************************************************
1990   079E             ;* Bit4 control function 9E:
1991   079E             ;* If control state A: 0111_xxxx
1992   079E             ;* Delete 1x2 screen objects (alien).
1993   079E             ;*****************************************************************************
1994   079E             L079E:
1995   079E EB                                 EX      DE,HL               ;
1996   079F 56                                 LD      D,(HL)              ; get MSB of screen ram
1997   07A0 23                                 INC     HL                  ;
1998   07A1 5E                                 LD      E,(HL)              ; get LSB of screen ram
1999   07A2 2B                                 DEC     HL                  ; restore pointer
2000   07A3 AF                                 XOR     A                   ; A=0
2001   07A4 12                                 LD      (DE),A              ; delete at screen, upper part
2002   07A5 13                                 INC     DE                  ;
2003   07A6 12                                 LD      (DE),A              ; delete at screen, lower part
2004   07A7 EB                                 EX      DE,HL               ;
2005   07A8 C9                                 RET                         ;
