5768   2771 A7                                 AND     A                   ; updates the zero flag
5769   2772 CA 78 27                           JP      Z,$2778             ; if GameAndDemoOrSplash is 'Game and demo for player 1'
5770   2775 11 21 40                           LD      DE,$4021            ; end of the screen area of player 2 score
5771   2778 CD C4 00                           CALL    PrintNumber         ; update the score on screen
5772   277B E1                                 POP     HL                  
