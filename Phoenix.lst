2167   085A 11 6C 08                           LD      DE,$086C            ;
2168   085D FE 11                              CP      $11                 ;
2169   085F D0                                 RET     NC                  ;
2170   0860 1E 6D                              LD      E,$6D               ;
2171   0862 FE 0D                              CP      $0D                 ;
2172   0864 D0                                 RET     NC                  ;
2173   0865 1E 6E                              LD      E,$6E               ;
2174   0867 FE 09                              CP      $09                 ;
2175   0869 D0                                 RET     NC                  ;
2176   086A 1E 6F                              LD      E,$6F               ;
2177   086C FE 05                              CP      $05                 ;
2178   086E D0                                 RET     NC                  ;
2179   086F 1E 68                              LD      E,$68               ;
2180   0871 C9                                 RET                         ;
