6748   34C0             ;*****************************************************************************
6749   34C0             ;* Draw a given bird object.
6750   34C0             ;* Input HL is the data structur of one bird object.
6751   34C0             ;* (For the 8 birds: $4B70, $4B78, $4B80, $4B88, $4B90, $4B98, $4BA0, $4BA8)
6752   34C0             ;*****************************************************************************
6753   34C0             DrawBirdObject:
6754   34C0 7E                                 LD      A,(HL)              ; HL=$4B70 (or $4B78,...)
6755   34C1 A7                                 AND     A                   ; updates the zero flag
6756   34C2 C8                                 RET     Z                   ; if 0
6757   34C3 47                                 LD      B,A                 ; save it
6758   34C4 C6 C0                              ADD     $C0                 ; add to base for table T3EC0
6759   34C6 5F                                 LD      E,A                 ; save it
6760   34C7 16 3E                              LD      D,$3E               ; MSB for T3EC0
6761   34C9 1A                                 LD      A,(DE)              ; get data starting from $3EC1
6762   34CA 4F                                 LD      C,A                 ;
6763   34CB 2C                                 INC     L                   ;
6764   34CC 56                                 LD      D,(HL)              ; get $4B71 MSB of screen ram
6765   34CD 2C                                 INC     L                   ;
6766   34CE 5E                                 LD      E,(HL)              ; get $4B72 LSB of screen ram
6767   34CF 2C                                 INC     L                   ;
6768   34D0 78                                 LD      A,B                 ; restore it
6769   34D1 07                                 RLCA                        ; Multiply by 8 ..
6770   34D2 07                                 RLCA                        ; ..
6771   34D3 07                                 RLCA                        ; ..
6772   34D4 86                                 ADD     A,(HL)              ; and add to $4B73 alien0 screen coordinate Y
6773   34D5 E6 7E                              AND     $7E                 ; mask out 0111_1110
6774   34D7 6F                                 LD      L,A                 ;
6775   34D8 26 3E                              LD      H,$3E               ;
6776   34DA 7E                                 LD      A,(HL)              ; get MSB from address table for bird character block shapes (T3E08)
6777   34DB 2C                                 INC     L                   ;
6778   34DC 6E                                 LD      L,(HL)              ; get LSB
6779   34DD 67                                 LD      H,A                 ;
6780   34DE             L34DE:
6781   34DE 7A                                 LD      A,D                 ;
6782   34DF FE 4B                              CP      $4B                 ; MSB of screen ram
6783   34E1 C2 0C 35                           JP      NZ,L350C            ; if value is not equal $4B
6784   34E4 7B                                 LD      A,E                 ;
6785   34E5 FE 50                              CP      $50                 ;
6786   34E7 DA 0C 35                           JP      C,L350C             ; 
6787   34EA 06 08                              LD      B,$08               ;
6788   34EC 2C                                 INC     L                   ;
