5736   2748             ; Add score values for enemies hit.
5737   2748             L2748:
5738   2748 1A                                 LD      A,(DE)              ; get $4370
5739   2749 1C                                 INC     E                   ;
5740   274A FE 01                              CP      $01                 ;
5741   274C C0                                 RET     NZ                  ; if not 1
5742   274D 1A                                 LD      A,(DE)              ;
5743   274E A7                                 AND     A                   ; updates the zero flag
5744   274F C8                                 RET     Z                   ;
5745   2750 0F                                 RRCA                        ; enemy has been hit
5746   2751 0F                                 RRCA                        ;
5747   2752 0F                                 RRCA                        ;
5748   2753 0F                                 RRCA                        ;
5749   2754 47                                 LD      B,A                 ;
