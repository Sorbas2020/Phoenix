2183   0876             ;*****************************************************************************
2184   0876             ; Updates the player ship, player bullet and the shield.
2185   0876             ;*****************************************************************************
2186   0876             PlayerUpdate:
2187   0876 CD 00 07                           CALL    PlayerDataController
2188   0879 CD 86 08                           CALL    L0886               ; copy current player data to old player data ?
2189   087C CD A0 08                           CALL    L08A0               ; update player position, bullet and shield
2190   087F CD A0 09                           CALL    L09A0               ; get screen ram adress for player ship position
2191   0882 CD 7A 09                           CALL    L097A               ; map player ship position to $439E $439F
2192   0885 C9                                 RET                         ;
2193   0886             
2194   0886             ;*****************************************************************************
2195   0886             ; Copy current player data to old player data.
2196   0886             ;*****************************************************************************
2197   0886             L0886:
2198   0886 21 EB 43                           LD      HL,M43EB            ;
2199   0889 06 03                              LD      B,$03               ;
2200   088B             L088B:
2201   088B 56                                 LD      D,(HL)              ;
2202   088C 2B                                 DEC     HL                  ;
2203   088D 5E                                 LD      E,(HL)              ;
2204   088E 2B                                 DEC     HL                  ;
2205   088F 72                                 LD      (HL),D              ;
2206   0890 2B                                 DEC     HL                  ;
2207   0891 73                                 LD      (HL),E              ;
2208   0892 2B                                 DEC     HL                  ;
2209   0893 05                                 DEC     B                   ;
2210   0894 C2 8B 08                           JP      NZ,L088B            ;
2211   0897 C9                                 RET                         ;
2212   0898             
2213   08A0                                    .ORG $08A0
2214   08A0             ;*****************************************************************************
2215   08A0             ;* Update player position, bullet and shield
2216   08A0             ;*****************************************************************************
2217   08A0             L08A0:
2218   08A0 CD C4 08                           CALL    MovePlayer          ;
2219   08A3 21 C4 43                           LD      HL,PlayerBulletState
2220   08A6 CD 30 09                           CALL    L0930               ; get the assigned player bullet tile if fire button was pressed
2221   08A9 3A B8 43                           LD      A,(LevelAndRound)   ;
2222   08AC E6 0F                              AND     $0F                 ; 0000_1111
2223   08AE FE 03                              CP      $03                 ;
2224   08B0 C0                                 RET     NZ                  ; return if not game level 3 (2nd alien wave)
2225   08B1 21 C8 43                           LD      HL,AbovePlayerBulletState
2226   08B4 CD 30 09                           CALL    L0930               ; get the assigned player bullet tile if fire button was pressed
2227   08B7 C9                                 RET                         ;
