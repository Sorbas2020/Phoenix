2136   0834             ;*****************************************************************************
2137   0834             ;* Game level 0 and 2:
2138   0834             ;* Stars scrolling down and 'aliens fade in'
2139   0834             ;*****************************************************************************
2140   0834             L0834:
2141   0834 CD F0 06                           CALL    L06F0               ; update scroll register and fill background
2142   0837 21 B4 43                           LD      HL,CounterB4        ; 
2143   083A 35                                 DEC     (HL)                ; decrement the counter
2144   083B 7E                                 LD      A,(HL)              ;
2145   083C FE 15                              CP      $15                 ;
2146   083E D0                                 RET     NC                  ;
2147   083F CD 5A 08                           CALL    GetAnimationChrs    ; for 'aliens fade in'
2148   0842 CD FA 05                           CALL    L05FA               ; init all alien control states
2149   0845 CD 50 0A                           CALL    AlienDataController ;
2150   0848             L0848:
2151   0848 21 B4 43                           LD      HL,CounterB4        ;
2152   084B 7E                                 LD      A,(HL)              ;
2153   084C A7                                 AND     A                   ; updates the zero flag
2154   084D C0                                 RET     NZ                  ; if CounterB4 is 0.
2155   084E 2E B8                              LD      L,$B8               ;
2156   0850 34                                 INC     (HL)                ; increment game level $43B8
2157   0851 2E A4                              LD      L,$A4               ; Next interval game state ...
2158   0853 36 02                              LD      (HL),$02            ; .. is 2
2159   0855 C9                                 RET                         ;
