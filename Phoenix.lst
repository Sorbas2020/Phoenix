5752   2758 78                                 LD      A,B                 ;
5753   2759 E6 0F                              AND     $0F                 ;
5754   275B 47                                 LD      B,A                 ;
5755   275C CD 20 02                           CALL    AddToScore          ; 
5756   275F AF                                 XOR     A                   ; Clear A Reg.
5757   2760 12                                 LD      (DE),A              ; clear the temp. score storage and ...
5758   2761 32 97 43                           LD      (M4397),A           ; ... the first two digits of BCD score value
5759   2764 C9                                 RET                         ;
