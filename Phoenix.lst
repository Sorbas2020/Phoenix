2289   0926             ;*****************************************************************************
2290   0926             ;* Get player ship animation frame values, mapped with T1600/T1620.
2291   0926             ;*****************************************************************************
2292   0926             L0926:
2293   0926 7E                                 LD      A,(HL)              ;
2294   0927 E6 07                              AND     $07                 ; mask out 0000_0111
2295   0929 81                                 ADD     A,C                 ;
2296   092A 4F                                 LD      C,A                 ;
2297   092B 0A                                 LD      A,(BC)              ; get data from table
2298   092C 2D                                 DEC     L                   ;
2299   092D 77                                 LD      (HL),A              ;
2300   092E C9                                 RET                         ;
2301   092F             
2302   0930                                    .ORG $0930
2303   0930             ;*****************************************************************************
2304   0930             ;* Get the assigned player bullet tile if fire button was pressed.
2305   0930             ;*****************************************************************************
2306   0930             L0930:
2307   0930 7E                                 LD      A,(HL)              ;
2308   0931 E6 08                              AND     $08                 ; mask out 0000_1000
2309   0933 C2 64 09                           JP      NZ,L0964            ; update PlayerBulletY (grid) and PlayerBulletState
2310   0936 EB                                 EX      DE,HL               ;
2311   0937 06 10                              LD      B,$10               ; 0001_0000 (bit4='fire')
2312   0939 CD BB 00                           CALL    CheckInputBits      ;
2313   093C C8                                 RET     Z                   ; return if button not pressed
2314   093D 7E                                 LD      A,(HL)              ;
2315   093E E6 EF                              AND     $EF                 ; mask out 1110_1111
2316   0940 77                                 LD      (HL),A              ;
2317   0941 1A                                 LD      A,(DE)              ;
2318   0942 F6 08                              OR      $08                 ; set bit3 at..
2319   0944 12                                 LD      (DE),A              ; $43C4 PlayerBulletState
2320   0945 13                                 INC     DE                  ;
2321   0946 13                                 INC     DE                  ;
2322   0947 3A C2 43                           LD      A,(PlayerShipX)     ;
2323   094A C6 04                              ADD     $04                 ; mask out 0000_0100
2324   094C 12                                 LD      (DE),A              ;
2325   094D 13                                 INC     DE                  ;
2326   094E 3A C3 43                           LD      A,(PlayerShipY)     ; $D8
2327   0951 D6 08                              SUB     $08                 ;
2328   0953 12                                 LD      (DE),A              ;
2329   0954 1B                                 DEC     DE                  ;
2330   0955 EB                                 EX      DE,HL               ;
2331   0956 01 20 16                           LD      BC,T1620            ; get character for player bullets
2332   0959 CD 26 09                           CALL    L0926               ; get player ship animation frame values, mapped with T1600/T1620
2333   095C 3E 30                              LD      A,$30               ; 0011_0000
2334   095E 32 61 43                           LD      (BulletTriggered),A ; set 'bullet triggered' flag
2335   0961 C9                                 RET                         ;
2336   0962             
2337   0964                                    .ORG $0964
2338   0964             ;*****************************************************************************
2339   0964             ;* Update PlayerBulletY (grid) and PlayerBulletState.
2340   0964             ;*****************************************************************************
2341   0964             L0964:
2342   0964 2C                                 INC     L                   ;
2343   0965 2C                                 INC     L                   ;
2344   0966 2C                                 INC     L                   ;
2345   0967 7E                                 LD      A,(HL)              ; get $43C7 PlayerBulletY (grid)
2346   0968 D6 08                              SUB     $08                 ; move bullet ($08 represents the bullet speed)
2347   096A 77                                 LD      (HL),A              ;
2348   096B FE 1F                              CP      $1F                 ; top of the screen reached?
2349   096D D0                                 RET     NC                  ; if not reached
2350   096E             L096E:
2351   096E 2D                                 DEC     L                   ;
2352   096F 2D                                 DEC     L                   ;
2353   0970 2D                                 DEC     L                   ;
2354   0971 7E                                 LD      A,(HL)              ; get $43C4 PlayerBulletState
2355   0972 E6 F7                              AND     $F7                 ; 1111_0111
2356   0974 77                                 LD      (HL),A              ; del bit3 at PlayerBulletState
2357   0975 C9                                 RET                         ;
2358   0976             
2359   097A                                    .ORG $097A
2360   097A             ;*****************************************************************************
2361   097A             ;* Player ship X position mapping.
2362   097A             ;*****************************************************************************
2363   097A             L097A:
2364   097A 3A C2 43                           LD      A,(PlayerShipX)     ;
2365   097D 47                                 LD      B,A                 ; save it
2366   097E E6 07                              AND     $07                 ; mask out 0000_0111
2367   0980 07                                 RLCA                        ;
2368   0981 21 38 0B                           LD      HL,T0B38            ; mapping table
2369   0984 85                                 ADD     A,L                 ;
2370   0985 6F                                 LD      L,A                 ;
2371   0986 78                                 LD      A,B                 ; restore it
2372   0987 96                                 SUB     (HL)                ;
2373   0988 32 9E 43                           LD      (M439E),A           ; Mapped player ship position, left part
2374   098B 23                                 INC     HL                  ;
2375   098C 78                                 LD      A,B                 ;
2376   098D 86                                 ADD     A,(HL)              ;
2377   098E 32 9F 43                           LD      (M439F),A           ; Mapped player ship position, right part
2378   0991 C9                                 RET                         ;
2379   0992             
2380   09A0                                    .ORG $09A0
2381   09A0             ;*****************************************************************************
2382   09A0             ;* Get screen ram adress for player and bullet positions.
2383   09A0             ;* from: 43C2:43C3, 43C6:43C7, 43CA:43CB
2384   09A0             ;* ......PlayerShipX
2385   09A0             ;* ...........PlayerShipY
2386   09A0             ;* .................PlayerBulletX
2387   09A0             ;* ......................PlayerBulletY
2388   09A0             ;* ............................AbovePlayerBulletX
2389   09A0             ;* .................................AbovePlayerBulletY
2390   09A0             ;* to:   43E2:43E3, 43E6:43E7, 43EA:43EB
2391   09A0             ;*****************************************************************************
2392   09A0             L09A0:
2393   09A0 01 C2 43                           LD      BC,PlayerShipX      ;
2394   09A3 11 E2 43                           LD      DE,PlayerShipMSB    ;
2395   09A6             L09A6:
2396   09A6 CD BA 09                           CALL    GetScreenRamAddress ;
2397   09A9 03                                 INC     BC                  ;
2398   09AA 03                                 INC     BC                  ;
2399   09AB 03                                 INC     BC                  ;
2400   09AC 13                                 INC     DE                  ;
2401   09AD 13                                 INC     DE                  ;
2402   09AE 13                                 INC     DE                  ;
2403   09AF 79                                 LD      A,C                 ;
2404   09B0 FE CE                              CP      $CE                 ; end of data structure
2405   09B2 C2 A6 09                           JP      NZ,L09A6            ;
2406   09B5 C9                                 RET                         ;
2407   09B6             
2408   09BA                                    .ORG $09BA
2409   09BA             ;*****************************************************************************
2410   09BA             ;* Mapping of 'grid values' to screen ram address.
2411   09BA             ;*****************************************************************************
2412   09BA             GetScreenRamAddress:
2413   09BA 21 00 0A                           LD      HL,T0A00            ; Screen ram addresses for the top row (left to right)
2414   09BD 0A                                 LD      A,(BC)              ; get the coordinate
2415   09BE E6 F8                              AND     $F8                 ; 1111_1000
2416   09C0 0F                                 RRCA                        ; 0111_1100
2417   09C1 0F                                 RRCA                        ; 0011_1110
2418   09C2 85                                 ADD     A,L                 ;
2419   09C3 6F                                 LD      L,A                 ;
2420   09C4 7E                                 LD      A,(HL)              ; get MSB of screen ram address for row
2421   09C5 12                                 LD      (DE),A              ; save it
2422   09C6 03                                 INC     BC                  ;
2423   09C7 13                                 INC     DE                  ;
2424   09C8 23                                 INC     HL                  ; move to LSB for T0A00
2425   09C9 0A                                 LD      A,(BC)              ; get the coordinate
2426   09CA E6 F8                              AND     $F8                 ; 1111_1000
2427   09CC 0F                                 RRCA                        ; 0111_1100
2428   09CD 0F                                 RRCA                        ; 0011_1110
2429   09CE 0F                                 RRCA                        ; 0001_1111
2430   09CF 86                                 ADD     A,(HL)              ; add to LSB of screen ram address for row
2431   09D0 12                                 LD      (DE),A              ; save it
2432   09D1 C9                                 RET                         ;
2433   09D2             
2434   0A00                                    .ORG $0A00
2435   0A00             ; Screen ram addresses for the top row (left to right)
2436   0A00             ; Notice these addresses are MSB:LSB (backwards from the processors endianness)
2437   0A00             T0A00:
2438   0A00                                    .MSFIRST
2439   0A00 43 20                              .DW ForegroundScreen+$320  ; Upper left corner of rotated screen
2440   0A02 43 00                              .DW ForegroundScreen+$300
2441   0A04 42 E0                              .DW ForegroundScreen+$2E0
2442   0A06 42 C0                              .DW ForegroundScreen+$2C0
2443   0A08 42 A0                              .DW ForegroundScreen+$2A0
2444   0A0A 42 80                              .DW ForegroundScreen+$280
2445   0A0C 42 60                              .DW ForegroundScreen+$260
2446   0A0E 42 40                              .DW ForegroundScreen+$240
2447   0A10 42 20                              .DW ForegroundScreen+$220
2448   0A12 42 00                              .DW ForegroundScreen+$200
2449   0A14 41 E0                              .DW ForegroundScreen+$1E0
2450   0A16 41 C0                              .DW ForegroundScreen+$1C0
2451   0A18 41 A0                              .DW ForegroundScreen+$1A0
2452   0A1A 41 80                              .DW ForegroundScreen+$180
2453   0A1C 41 60                              .DW ForegroundScreen+$160
2454   0A1E 41 40                              .DW ForegroundScreen+$140
2455   0A20 41 20                              .DW ForegroundScreen+$120
2456   0A22 41 00                              .DW ForegroundScreen+$100
2457   0A24 40 E0                              .DW ForegroundScreen+$E0
2458   0A26 40 C0                              .DW ForegroundScreen+$C0
2459   0A28 40 A0                              .DW ForegroundScreen+$A0
2460   0A2A 40 80                              .DW ForegroundScreen+$80
2461   0A2C 40 60                              .DW ForegroundScreen+$60
2462   0A2E 40 40                              .DW ForegroundScreen+$40
2463   0A30 40 20                              .DW ForegroundScreen+$20
2464   0A32 40 00                              .DW ForegroundScreen       ; Upper right corner of rotated screen
2465   0A34             
2466   0A34             ; Mapping the 'out of screen' objects
2467   0A34 00 00                              .DB $00, $00
2468   0A36 00 00                              .DB $00, $00
2469   0A38 00 00                              .DB $00, $00
2470   0A3A 00 00                              .DB $00, $00
2471   0A3C 00 00                              .DB $00, $00
2472   0A3E 00 00                              .DB $00, $00
2473   0A40             ;
2474   0A40             T0A40:
2475   0A40 AA BA AB BB                        .DB $AA, $BA, $AB, $BB     ;alien shape #37 (set A)
2476   0A44 80 90 81 91                        .DB $80, $90, $81, $91     ;alien shape #34 (set A)
2477   0A48             T0A48:
2478   0A48 74 7C 75 7D                        .DB $74, $7C, $75, $7D     ;alien pilot shape (set B)
