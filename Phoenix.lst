2102   0800             ;*****************************************************************************
2103   0800             ;* Game state 3.
2104   0800             ;* Normal game play.
2105   0800             ;*****************************************************************************
2106   0800             L0800:
2107   0800 21 14 08                           LD      HL,T0814            ;
2108   0803 3A B8 43                           LD      A,(LevelAndRound)   ; bit0 - 3: game level, bit4 - 7: game round
2109   0806 07                                 RLCA                        ; Multiply by 2 to get a 2 byte offset
2110   0807 E6 1E                              AND     $1E                 ; mask out 0001_1110 game level
2111   0809 85                                 ADD     A,L                 ; add offset ...
2112   080A 6F                                 LD      L,A                 ; ... to base of table
2113   080B 7E                                 LD      A,(HL)              ; MSB of destination
2114   080C 2C                                 INC     L                   ; Get the
2115   080D 6E                                 LD      L,(HL)              ; ... LSB of destination
2116   080E 67                                 LD      H,A                 ; Now point to function
2117   080F E9                                 JP      (HL)                ; jump to corresponding function according to LevelAndRound.
2118   0810             
2119   0814                                    .ORG $0814
2120   0814             T0814:
2121   0814                                    .MSFIRST
2122   0814 08 34                              .DW L0834       ;Game level 0: called for each frame during stars scrolling down and 'aliens fade in'
2123   0816 20 00                              .DW L2000       ;Game level 1: called for each frame during 'player alife' with aliens, after 'fade in'
2124   0818 08 34                              .DW L0834       ;Game level 2: called for each frame during stars scrolling down and 'aliens fade in'
2125   081A 20 00                              .DW L2000       ;Game level 3: called for each frame during 'player alife' with aliens, after 'fade in'
2126   081C 22 30                              .DW L2230       ;Game level 4: called for each frame during 'spiral fill'
2127   081E 34 00                              .DW L3400       ;Game level 5: called for each frame during birds level including 'fade in'
2128   0820 22 30                              .DW L2230       ;Game level 6: called for each frame during 'spiral fill'
2129   0822 34 00                              .DW L3400       ;Game level 7: called for each frame during birds level including 'fade in'
2130   0824 22 30                              .DW L2230       ;Game level 8: called for each frame during 'spiral fill'
2131   0826 22 B4                              .DW L22B4       ;Game level 9: called for each frame during mothership 'fade in'
2132   0828 22 CA                              .DW L22CA       ;Game level A: called for each frame during mothership and aliens 'fade in'
2133   082A 20 00                              .DW L2000       ;Game level B: called for each frame during 'player alife' with aliens and mothership, after 'fade in'
2134   082C             
