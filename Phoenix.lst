2011   07AA             ;* Draw 1x2 screen objects (alien).
2012   07AA             ;*****************************************************************************
2013   07AA             L07AA:
2014   07AA EB                                 EX      DE,HL               ;
2015   07AB 23                                 INC     HL                  ;
2016   07AC 23                                 INC     HL                  ;
2017   07AD 56                                 LD      D,(HL)              ;
2018   07AE 23                                 INC     HL                  ;
2019   07AF 5E                                 LD      E,(HL)              ;
2020   07B0 0A                                 LD      A,(BC)              ;
2021   07B1 6F                                 LD      L,A                 ;
2022   07B2 26 14                              LD      H,T1420 >> 8        ; get alien character block shapes table
2023   07B4 7E                                 LD      A,(HL)              ;
2024   07B5 12                                 LD      (DE),A              ; draw upper part on screen
2025   07B6 23                                 INC     HL                  ;
2026   07B7 13                                 INC     DE                  ;
2027   07B8 7E                                 LD      A,(HL)              ;
2028   07B9 12                                 LD      (DE),A              ; draw lower part on screen
2029   07BA 0B                                 DEC     BC                  ;
2030   07BB C9                                 RET                         ;
2031   07BC             
2032   07BE                                    .ORG $07BE
2033   07BE             ;*****************************************************************************
2034   07BE             ;* Bit4 control function BE:
2035   07BE             ;* If control state A: 1001_xxxx
2036   07BE             ;* Delete 2x2 screen objects (player ship, alien).
2037   07BE             ;*****************************************************************************
2038   07BE             L07BE:
2039   07BE EB                                 EX      DE,HL               ;
2040   07BF 56                                 LD      D,(HL)              ;
2041   07C0 23                                 INC     HL                  ;
2042   07C1 5E                                 LD      E,(HL)              ;
2043   07C2 2B                                 DEC     HL                  ;
2044   07C3 AF                                 XOR     A                   ; A=0
2045   07C4 12                                 LD      (DE),A              ; delete upper left part
2046   07C5 13                                 INC     DE                  ;
2047   07C6 12                                 LD      (DE),A              ; delete upper right part
2048   07C7 CD 17 02                           CALL    RightOneColumn      ;
2049   07CA AF                                 XOR     A                   ; A=0
2050   07CB 12                                 LD      (DE),A              ; delete lower left part
2051   07CC 1B                                 DEC     DE                  ;
2052   07CD 12                                 LD      (DE),A              ; delete lower right part
2053   07CE EB                                 EX      DE,HL               ;
2054   07CF C9                                 RET                         ;
2055   07D0             
2056   07D2                                    .ORG $07D2
2057   07D2             ;*****************************************************************************
2058   07D2             ;* Bit3 control function D2:
2059   07D2             ;* If control state A: xxxx_1100
2060   07D2             ;* Draw 2x2 screen objects (player ship, alien, planets).
2061   07D2             ;*****************************************************************************
2062   07D2             L07D2:
2063   07D2 EB                                 EX      DE,HL               ;
2064   07D3 23                                 INC     HL                  ;
2065   07D4 23                                 INC     HL                  ;
2066   07D5 56                                 LD      D,(HL)              ; get MSB from player data structure (screen ram)
2067   07D6 23                                 INC     HL                  ;
2068   07D7 5E                                 LD      E,(HL)              ; get LSB from player data structure (screen ram)
2069   07D8 0A                                 LD      A,(BC)              ; get value from player data structure (grid)
2070   07D9 6F                                 LD      L,A                 ;
2071   07DA 26 14                              LD      H,T1400 >> 8        ; get player ship character block shapes table
2072   07DC             L07DC:
2073   07DC 7E                                 LD      A,(HL)              ; Entry point for general draw
2074   07DD 12                                 LD      (DE),A              ; draw upper left part
2075   07DE 23                                 INC     HL                  ;
2076   07DF 13                                 INC     DE                  ;
2077   07E0 7E                                 LD      A,(HL)              ;
2078   07E1 12                                 LD      (DE),A              ; draw upper right part
2079   07E2 23                                 INC     HL                  ;
2080   07E3 1B                                 DEC     DE                  ;
2081   07E4 CD 17 02                           CALL    RightOneColumn      ;
2082   07E7 7E                                 LD      A,(HL)              ;
2083   07E8 12                                 LD      (DE),A              ; draw lower left part
2084   07E9 23                                 INC     HL                  ;
2085   07EA 13                                 INC     DE                  ;
2086   07EB 7E                                 LD      A,(HL)              ;
2087   07EC 12                                 LD      (DE),A              ; draw lower right part
2088   07ED 0B                                 DEC     BC                  ;
2089   07EE C9                                 RET                         ;
