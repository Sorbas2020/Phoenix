0015   0000             
0016   0000             ; ForegroundScreen.
0017   0000             ForegroundScreen       .EQU $4000       ;32*26 bytes for the foreground screen
0018   0000             
0019   0000             ; General storage.
0020   0000             ; Alien-formation attack controller data:
0021   0000             ; Drives when and how aliens break out of the base formation to fly their "closed loop" swooping attack patterns.
0022   0000             ; The whole structure (`$4350`–`$437F`) is zeroed at level init by the routine at `$32B0`,
0023   0000             ; and it's serviced every frame by a 7 way state machine dispatched through the jump table `T3018` (indexed by `Counter93`),
0024   0000             ; with each handler reading/updating the behavior state in `$4350`.
0025   0000             M4350                  .EQU $4350       ;Alien behavior state (the state-machine variable, values 0–6)
0026   0000             M4351                  .EQU $4351       ;MSB of next closed loop pattern (into the `T2Exx` / `T3330` pattern tables)
0027   0000             M4352                  .EQU $4352       ;LSB of next closed loop pattern (into the `T2Exx` / `T3330` pattern tables)
0028   0000             M4353                  .EQU $4353       ;Number of aliens doing the closed loop pattern (how many attackers)
0029   0000             M4354                  .EQU $4354       ;LSB pointer to the currently selected lead attacking alien (`$4B50`/`$4B72` grid slot)
0030   0000             M4355                  .EQU $4355       ;Delay counter before the next attack is armed (→ behavior state 1)
0031   0000             M4356                  .EQU $4356       ;Rotating 0–15 "movement start" index (from `$4395`) used to sync aliens
0032   0000             M4357                  .EQU $4357       ;Attack-cycle/escalation counter (0–3); scales attacker count and difficulty
0033   0000             M4358                  .EQU $4358       ;Inter-step timer for the angry downward-push movement pattern
0034   0000             M4359                  .EQU $4359       ;Staggered group countdown timer 1 for phased alien launches
0035   0000             M435A                  .EQU $435A       ;Staggered group countdown timer 2 for phased alien launches
0036   0000             M435B                  .EQU $435B       ;Staggered group countdown timer 3 for phased alien launches
0037   0000             
0038   0000             ; Flags and counter
0039   0000             M435E                  .EQU $435E       ;Flag for: 'AliensLeft < 5' ($FF)
0040   0000             M435F                  .EQU $435F       ;8 bit counter for alien movement
0041   0000             PlayerMoved            .EQU $4360       ;Flag for: 'Player moved' ($FF)
0042   0000             BulletTriggered        .EQU $4361       ;Flag for: 'Bullet triggered' ($30) and counter
0043   0000             M4362                  .EQU $4362       ;Flag for: 'Player shield active' and animation counter
0044   0000             ParticleExplosion      .EQU $4363       ;Flag for: 'Particle explosion start' and animation counter
0045   0000             M4364                  .EQU $4364       ;Flag for: 'Enemy hit detected' ($FF) and counter
0046   0000             
0047   0000             M4366                  .EQU $4366       ;Flag for: 'Mothership or bird wing hit detected' ($FF)
0048   0000             M4367                  .EQU $4367       ;Flag for: 'Mothership partially faded in' ($FF)
0049   0000             M4368                  .EQU $4368       ;Maturity of the birds. From 'egg' over 'no wings' to 'adult' ($01 to $0F)
0050   0000             M4369                  .EQU $4369       ;Flag for: 'Bonus explosion' ($FF)
0051   0000             M436A                  .EQU $436A       ;Flag for: 'Bonus live added' ($FF) and counter
0052   0000             M436B                  .EQU $436B       ;Flag for: 'Mother ship score display' ($FF) and counter
0053   0000             
0054   0000             ; Shape of the next bird attack:
0055   0000             ; `$436D` says where they enter,
0056   0000             ; `$436E` says how many birds,
0057   0000             ; `$436F` adds the random variation that keeps successive waves from being identical.
0058   0000             ; All three are recomputed by `L3560` each time a new bird group is dispatched.
0059   0000             M436D                  .EQU $436D       ;Horizontal start position of the bird group
0060   0000             M436E                  .EQU $436E       ;Bird count / formation-size for the wave
0061   0000             M436F                  .EQU $436F       ;Per-wave random variation seed
0062   0000             
0063   0000             M4370                  .EQU $4370       ;Explosion slot0 animation index
0064   0000             M4371                  .EQU $4371       ;Explosion slot0 BCD score value (last digit is ever 0)
0065   0000             M4372                  .EQU $4372       ;Explosion slot0 MSB screen ram
0066   0000             M4373                  .EQU $4373       ;Explosion slot0 LSB screen ram
0067   0000             M4374                  .EQU $4374       ;Explosion slot1 animation index
0068   0000             M4375                  .EQU $4375       ;Explosion slot1 BCD score value (last digit is ever 0)
0069   0000             M4376                  .EQU $4376       ;Explosion slot1 MSB screen ram
0070   0000             M4377                  .EQU $4377       ;Explosion slot1 LSB screen ram
0071   0000             M4378                  .EQU $4378       ;Bonus explosion slot0 animation index
0072   0000             M4379                  .EQU $4379       ;Bonus explosion slot0 BCD score value (last digit is ever 0)
0073   0000             M437A                  .EQU $437A       ;Bonus explosion slot0 MSB screen ram
0074   0000             M437B                  .EQU $437B       ;Bonus explosion slot0 LSB screen ram
0075   0000             M437C                  .EQU $437C       ;Bonus explosion slot1 animation index
0076   0000             M437D                  .EQU $437D       ;Bonus explosion slot1 BCD score value (last digit is ever 0)
0077   0000             M437E                  .EQU $437E       ;Bonus explosion slot1 MSB screen ram
0078   0000             M437F                  .EQU $437F       ;Bonus explosion slot1 LSB screen ram
0079   0000             M4380                  .EQU $4380       ;Ever set to 0 (prevents overflow)
0080   0000             Score1high             .EQU $4381       ;Player 1 score BCD (high)
0081   0000             Score1mid              .EQU $4382       ;Player 1 score BCD (mid)
0082   0000             Score1low              .EQU $4383       ;Player 1 score BCD (low)
0083   0000             M4384                  .EQU $4384       ;Ever set to 0 (prevents overflow)
0084   0000             Score2high             .EQU $4385       ;Player 2 score BCD (high)
0085   0000             Score2mid              .EQU $4386       ;Player 2 score BCD (mid)
0086   0000             Score2low              .EQU $4387       ;Player 2 score BCD (low)
0087   0000             M4388                  .EQU $4388       ;Ever set to 0 (prevents overflow)
0088   0000             HiScorehigh            .EQU $4389       ;Hi score BCD (high)
0089   0000             HiScoremid             .EQU $438A       ;Hi score BCD (mid)
0090   0000             HiScorelow             .EQU $438B       ;Hi score BCD (low)
0091   0000             SoundControlA          .EQU $438C       ;RAM copy of sound device control register A (0x6000)
0092   0000             SoundControlB          .EQU $438D       ;RAM copy of sound device control register B (0x6800)
0093   0000             M438E                  .EQU $438E       ;Bird-wave background-sound phase (advances the melody, low bit drives SoundControlB)
0094   0000             CoinCount              .EQU $438F       ;Number of coins inserted (max is 9)
0095   0000             Player1Lives           .EQU $4390       ;Player 1 number of lives
0096   0000             Player2Lives           .EQU $4391       ;Player 2 number of lives
0097   0000             M4392                  .EQU $4392       ;Ever set to 0 ?
0098   0000             Counter93              .EQU $4393       ;Free running counter during playtime at game level 3
0099   0000             M4394                  .EQU $4394       ;Start value list pointer for alien movement MSB
0100   0000             M4395                  .EQU $4395       ;Start value list pointer for alien movement LSB
0101   0000             M4396                  .EQU $4396       ;Bird-wave background-sound step timer (counts frames per tone vs `T3DE0` duration)
0102   0000             M4397                  .EQU $4397       ;Score "dirty" flag — `0` means score changed this frame -> redraw the digits
0103   0000             M4398                  .EQU $4398       ;16 bit counter (MSB) actual index for slow print at intro splash
0104   0000             M4399                  .EQU $4399       ;16 bit counter (LSB) actual index for slow print at intro splash
0105   0000             Counter9A              .EQU $439A       ;16 bit counter (MSB) for animation
0106   0000             M439B                  .EQU $439B       ;16 bit counter (LSB) for animation and next index for slow print at intro splash
0107   0000             M439C                  .EQU $439C       ;Spiral-fill animation step counter (level 4/6/8 inter-wave fade-in)
0108   0000             M439D                  .EQU $439D       ;Fist two digits of BCD score value for mothership explosion
0109   0000             M439E                  .EQU $439E       ;Mapped player ship position, left part: ($09 to $C0)
0110   0000             M439F                  .EQU $439F       ;Mapped player ship position, right part: ($17 to $C8)
0111   0000             IN0Current             .EQU $43A0       ;Current value of IN0: bit0='coin', bit1='1 player', bit2='2 players', bit4='fire', bit5='right', bit6='left', bit7='shield'
0112   0000             IN0Previous            .EQU $43A1       ;Previous value of IN0
0113   0000             GameOrAttract          .EQU $43A2       ;Attract mode=0, One player game mode=1, Two players game mode=2
0114   0000             GameAndDemoOrSplash    .EQU $43A3       ;Game and demo for player 1=0, Game for player 2=1, Intro splash=2
0115   0000             GameState              .EQU $43A4       ;Game state=0 - 7
0116   0000             CounterA5              .EQU $43A5       ;8 bit counter (e.g.: score flash time)
0117   0000             ShieldCount            .EQU $43A6       ;Counts shield time and controls shield picture. Shields end at C0.
0118   0000             AnimationCounter       .EQU $43A7       ;For mothership's antenna and the alien pilot animation
0119   0000             M43A8                  .EQU $43A8       ;Temporary storage (MSB of pointer to table $1860)
0120   0000             M43A9                  .EQU $43A9       ;Temporary storage (LSB of pointer to table $1860)
0121   0000             M43AA                  .EQU $43AA       ;Mothership-wave frame counter (times antenna/pilot animation and star scroll)
0122   0000             M43AB                  .EQU $43AB       ;Counter for planet trigger
0123   0000             M43AC                  .EQU $43AC       ;Planet vertical spacing increment (added to trigger `$43AB`)
0124   0000             M43AD                  .EQU $43AD       ;Planet X index -> `T1E60` (screen-RAM LSB), incremented per planet
0125   0000             M43AE                  .EQU $43AE       ;Planet X index -> `T1E20` (screen-RAM MSB), incremented per planet
0126   0000             M43AF                  .EQU $43AF       ;`CounterB9` trigger for the next galaxy
0127   0000             M43B0                  .EQU $43B0       ;Galaxy spacing decrement (subtracted from `$43AF`)
0128   0000             M43B1                  .EQU $43B1       ;Galaxy X index -> `T1E80`, incremented per galaxy
0129   0000             M43B2                  .EQU $43B2       ;MSB pointer into the background pattern tables `T1C00`/`T1D00`/`T1F00`
0130   0000             M43B3                  .EQU $43B3       ;LSB pointer into the background pattern tables `T1C00`/`T1D00`/`T1F00`
0131   0000             CounterB4              .EQU $43B4       ;8 bit counter (stars scrolling down, aliens fade in time)
0132   0000             M43B5                  .EQU $43B5       ;Reserved/unused byte always `$FF`
0133   0000             M43B6                  .EQU $43B6       ;End-of-wave countdown timer that advances the game to the next level/round
0134   0000             
0135   0000             LevelAndRound          .EQU $43B8       ;Bit0 - 3: game level, bit4 - 7: game round
0136   0000             CounterB9              .EQU $43B9       ;8 bit backwards counter
0137   0000             AliensLeft             .EQU $43BA       ;Number of aliens left in wave (16 at new)
0138   0000             BirdsLeft              .EQU $43BB       ;Number of birds left in wave (8 at new)
0139   0000             M43BC                  .EQU $43BC       ;Reserved/unused byte
0140   0000             M43BD                  .EQU $43BD       ;
0141   0000             BonusLivesAt           .EQU $43BE       ;Bonus lives (at 30K, 40K, 50K or 60K) from DIP switch settings
0142   0000             M43BF                  .EQU $43BF       ;
0143   0000             
0144   0000             ; Player and player bullets, data structure (grid).
0145   0000             PlayerState            .EQU $43C0       ;Player ship control state register
0146   0000             PlayerShape            .EQU $43C1       ;LSB for T1400 player ship character block shapes table
0147   0000             PlayerShipX            .EQU $43C2       ;Player ship, coordinate X ($0C=min.left, $64=default, $C0=max.right)
0148   0000             PlayerShipY            .EQU $43C3       ;Player ship, coordinate Y ($D8)
0149   0000             PlayerBulletState      .EQU $43C4       ;Player bullet, control state register
0150   0000             PlayerBulletShape      .EQU $43C5       ;Player bullet, character code ($50 to $57)
0151   0000             PlayerBulletX          .EQU $43C6       ;Player bullet, coordinate X
0152   0000             PlayerBulletY          .EQU $43C7       ;Player bullet, coordinate Y ($D0=min.bottom, $18=max.top)
0153   0000             AbovePlayerBulletState .EQU $43C8       ;One position above player bullet, control state register
0154   0000             AbovePlayerBulletShape .EQU $43C9       ;One position above player bullet, character code ($50 to $57)
0155   0000             AbovePlayerBulletX     .EQU $43CA       ;One position above player bullet, coordinate X
0156   0000             AbovePlayerBulletY     .EQU $43CB       ;One position above player bullet, coordinate Y
0157   0000             
0158   0000             ; Alien and bird bullets, data structure (grid).
0159   0000             AlienBullet0State      .EQU $43CC       ;Enemy bullet 0, control state register
0160   0000             AlienBullet0Shape      .EQU $43CD       ;Enemy bullet 0, character code ($58 to $5F)
0161   0000             AlienBullet0X          .EQU $43CE       ;Enemy bullet 0, coordinate X
0162   0000             AlienBullet0Y          .EQU $43CF       ;Enemy bullet 0, coordinate Y
0163   0000             AlienBullet1State      .EQU $43D0       ;Enemy bullet 1, control state register
0164   0000             AlienBullet1Shape      .EQU $43D1       ;Enemy bullet 1, character code ($58 to $5F)
0165   0000             AlienBullet1X          .EQU $43D2       ;Enemy bullet 1, coordinate X
0166   0000             AlienBullet1Y          .EQU $43D3       ;Enemy bullet 1, coordinate Y
0167   0000             AlienBullet2State      .EQU $43D4       ;Enemy bullet 2, control state register
0168   0000             AlienBullet2Shape      .EQU $43D5       ;Enemy bullet 2, character code ($58 to $5F)
0169   0000             AlienBullet2X          .EQU $43D6       ;Enemy bullet 2, coordinate X
0170   0000             AlienBullet2Y          .EQU $43D7       ;Enemy bullet 2, coordinate Y
0171   0000             AlienBullet3State      .EQU $43D8       ;Enemy bullet 3, control state register
0172   0000             AlienBullet3Shape      .EQU $43D9       ;Enemy bullet 3, character code ($58 to $5F)
0173   0000             AlienBullet3X          .EQU $43DA       ;Enemy bullet 3, coordinate X
0174   0000             AlienBullet3Y          .EQU $43DB       ;Enemy bullet 3, coordinate Y
0175   0000             AlienBullet4State      .EQU $43DC       ;Enemy bullet 4, control state register
0176   0000             AlienBullet4Shape      .EQU $43DD       ;Enemy bullet 4, character code ($58 to $5F)
0177   0000             AlienBullet4X          .EQU $43DE       ;Enemy bullet 4, coordinate X
0178   0000             AlienBullet4Y          .EQU $43DF       ;Enemy bullet 4, coordinate Y
